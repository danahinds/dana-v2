---
import Layout from "./Layout.astro";

const { frontmatter } = Astro.props;

const formatDate = (d) => {
  const date = d instanceof Date ? d : new Date(d);
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
};

const plainTitle = frontmatter.title.replace(/<[^>]+>/g, "");
const partLabel = frontmatter.part ? String(frontmatter.part).padStart(2, "0") : null;
---

<Layout pageTitle={plainTitle} pageDescription={frontmatter.description}>

  <div class="skai-post">

    <!-- ORB LAYER -->
    <div class="orb-layer">
      <div class="orb orb-a"></div>
      <div class="orb orb-b"></div>
      <div class="orb orb-c"></div>
      <div class="orb orb-d"></div>
      <div class="orb orb-e"></div>
    </div>

    <!-- HERO -->
    <section class="post-hero">
      {partLabel && <div class="hero-ghost">{partLabel}</div>}

      <div class="hero-content">
        <div class="hero-text">
          {frontmatter.series && (
            <p class="hero-label">
              {frontmatter.series}
              {frontmatter.part && <> <span class="divider">·</span> Part {frontmatter.part}</>}
            </p>
          )}
          <h1 class="hero-title" set:html={frontmatter.title} />
          <p class="hero-byline">
            By {frontmatter.author}
            <span class="divider">·</span>
            {formatDate(frontmatter.pubDate)}
            {frontmatter.readTime && (
              <>
                <span class="divider">·</span>
                <span class="read-time">{frontmatter.readTime}</span>
              </>
            )}
          </p>
          <p class="hero-credit">
            <em>Written with the editorial assistance of Claude (Anthropic).</em>
          </p>
        </div>

        {frontmatter.heroIllustration && (
          <div class="hero-illustration">
            <img
              src={frontmatter.heroIllustration.url}
              alt={frontmatter.heroIllustration.alt}
            />
          </div>
        )}
      </div>
    </section>

    {frontmatter.heroIllustration?.caption && (
      <p class="hero-caption">{frontmatter.heroIllustration.caption}</p>
    )}

    <!-- GOLD DIVIDER -->
    <svg class="gold-divider" viewBox="0 0 1440 48" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0 24 Q180 4 360 24 T720 24 T1080 24 T1440 24" fill="none" stroke="rgba(156,122,62,0.45)" stroke-width="1"/>
      <path d="M0 32 Q240 48 480 28 T960 32 T1440 28" fill="none" stroke="rgba(156,122,62,0.2)" stroke-width="0.75"/>
      <circle cx="360" cy="24" r="3" fill="rgba(156,122,62,0.55)"/>
      <circle cx="720" cy="24" r="2" fill="rgba(156,122,62,0.45)"/>
      <circle cx="1080" cy="24" r="3" fill="rgba(156,122,62,0.55)"/>
    </svg>

    <!-- POST BODY -->
    <section class="post-body reveal">
      <div class="prose">
        <slot />
      </div>
    </section>

    <!-- GOLD DIVIDER -->
    <svg class="gold-divider" viewBox="0 0 1440 48" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <line x1="72" y1="24" x2="400" y2="24" stroke="rgba(156,122,62,0.5)" stroke-width="0.75"/>
      <circle cx="400" cy="24" r="2.5" fill="none" stroke="rgba(156,122,62,0.55)" stroke-width="1"/>
      <line x1="406" y1="24" x2="700" y2="24" stroke="rgba(156,122,62,0.25)" stroke-width="0.5" stroke-dasharray="4 6"/>
      <circle cx="700" cy="24" r="1.5" fill="rgba(156,122,62,0.45)"/>
      <line x1="706" y1="24" x2="1040" y2="24" stroke="rgba(156,122,62,0.25)" stroke-width="0.5" stroke-dasharray="4 6"/>
      <circle cx="1040" cy="24" r="2.5" fill="none" stroke="rgba(156,122,62,0.55)" stroke-width="1"/>
      <line x1="1046" y1="24" x2="1370" y2="24" stroke="rgba(156,122,62,0.5)" stroke-width="0.75"/>
    </svg>

    <!-- NEXT POST -->
    {frontmatter.nextPart && (
      <aside class="next-post">
        <div class="next-post-inner">
          <p class="next-post-label">Next in the series</p>
          <a href={`/posts/${frontmatter.nextPart.slug}`} class="next-post-link">
            {frontmatter.nextPart.label} <span class="arrow">→</span>
          </a>
        </div>
      </aside>
    )}

  </div>

</Layout>

<script>
  function initPost() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.05 });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
    setTimeout(() => {
      document.querySelectorAll('.reveal:not(.visible)').forEach(el => el.classList.add('visible'));
    }, 3000);
  }
  document.addEventListener('astro:page-load', initPost);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPost);
  } else {
    initPost();
  }
</script>

<!-- Cream surface — scoped to .skai-post only -->
<style is:global>
  .skai-post {
    --cream-bg: #f5f0e8;
    --ink: #2c3a22;
    --ink-muted: rgba(44, 58, 34, 0.68);
    --ink-subtle: rgba(44, 58, 34, 0.5);
    --ink-whisper: rgba(44, 58, 34, 0.35);
    --blog-accent: #9c7a3e; /* brown-gold — stronger contrast on cream than mid-olive */
    --border-soft: rgba(44, 58, 34, 0.15);
    --border-whisper: rgba(156, 122, 62, 0.25);
    background: var(--cream-bg);
    position: relative;
    z-index: 1;
    overflow: hidden;
  }
</style>

<style>
  /* ─── ORB LAYER (olive + gold tints on cream) ─── */
  .orb-layer {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }
  .orb {
    position: absolute;
    border-radius: 50%;
  }
  .orb-a {
    width: 300px; height: 300px; top: 8vh; left: 4vw;
    background: radial-gradient(circle, rgba(44, 58, 34, 0.08) 0%, transparent 70%);
    animation: floatOrb 9s ease-in-out infinite;
  }
  .orb-b {
    width: 200px; height: 200px; top: 30vh; right: 5vw;
    background: radial-gradient(circle, rgba(156, 122, 62, 0.12) 0%, transparent 70%);
    animation: floatOrb 12s ease-in-out 1.5s infinite;
  }
  .orb-c {
    width: 140px; height: 140px; top: 58vh; left: 18vw;
    background: radial-gradient(circle, rgba(44, 58, 34, 0.07) 0%, transparent 70%);
    animation: floatOrb 7s ease-in-out 3s infinite;
  }
  .orb-d {
    width: 90px; height: 90px; top: 72vh; right: 22vw;
    background: radial-gradient(circle, rgba(156, 122, 62, 0.14) 0%, transparent 70%);
    animation: floatOrb 10s ease-in-out 0.8s infinite;
  }
  .orb-e {
    width: 240px; height: 240px; bottom: 6vh; right: 3vw;
    background: radial-gradient(circle, rgba(44, 58, 34, 0.06) 0%, transparent 70%);
    animation: floatOrb 14s ease-in-out 2s infinite;
  }
  @keyframes floatOrb {
    0%, 100% { transform: translateY(0) scale(1); }
    50% { transform: translateY(-30px) scale(1.06); }
  }

  /* ─── HERO ─── */
  .post-hero {
    padding: 160px 72px 40px;
    position: relative;
    overflow: hidden;
  }

  .hero-ghost {
    position: absolute;
    right: 48px;
    top: 110px;
    font-family: var(--font-display);
    font-weight: 600;
    font-style: italic;
    font-size: clamp(120px, 20vw, 260px);
    color: transparent;
    -webkit-text-stroke: 1px rgba(44, 58, 34, 0.12);
    pointer-events: none;
    user-select: none;
    line-height: 1;
    opacity: 0;
    animation: fadeIn 1.4s ease 0.9s forwards;
  }

  .hero-content {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 48px;
    max-width: 1400px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .hero-text {
    flex: 1;
    min-width: 0;
  }

  .hero-label {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: clamp(15px, 1.7vw, 20px);
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: #9c7a3e;
    margin-bottom: 28px;
    opacity: 0;
    animation: fadeUp 0.9s ease 0.1s forwards;
  }
  .hero-label .divider {
    margin: 0 10px;
    opacity: 0.55;
    font-weight: 400;
  }

  .hero-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(44px, 7vw, 96px);
    line-height: 1.0;
    letter-spacing: -0.02em;
    color: #2c3a22;
    margin: 0 0 32px 0;
    opacity: 0;
    animation: fadeUp 0.9s ease 0.25s forwards;
  }
  .hero-title :global(em) {
    font-style: italic;
    color: #9c7a3e;
  }

  .hero-byline {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 13px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(44, 58, 34, 0.68);
    margin: 0 0 8px 0;
    opacity: 0;
    animation: fadeUp 0.9s ease 0.45s forwards;
  }
  .hero-byline .divider {
    margin: 0 10px;
    opacity: 0.5;
  }

  .hero-credit {
    font-family: var(--font-display);
    color: rgba(44, 58, 34, 0.5);
    font-size: 14px;
    line-height: 1.5;
    margin: 0;
    opacity: 0;
    animation: fadeUp 0.9s ease 0.55s forwards;
  }
  .hero-credit em {
    font-style: italic;
  }

  /* ─── HERO ILLUSTRATION ─── */
  .hero-illustration {
    flex-shrink: 0;
    width: 520px;
    max-width: 42vw;
    opacity: 0;
    animation: fadeIn 1s ease 0.5s forwards, illuFloat 7s ease-in-out 1.5s infinite;
  }
  .hero-illustration img {
    width: 100%;
    display: block;
    /* Feather the rectangular cream background into the page cream */
    -webkit-mask-image: radial-gradient(ellipse 85% 90% at center, #000 55%, rgba(0,0,0,0.85) 70%, transparent 98%);
    mask-image: radial-gradient(ellipse 85% 90% at center, #000 55%, rgba(0,0,0,0.85) 70%, transparent 98%);
    mix-blend-mode: multiply;
  }
  @keyframes illuFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-16px); }
  }

  .hero-caption {
    font-family: var(--font-display);
    font-style: italic;
    text-align: center;
    color: rgba(44, 58, 34, 0.65);
    font-size: 15px;
    line-height: 1.5;
    max-width: 640px;
    margin: 0 auto 24px;
    padding: 0 32px;
    position: relative;
    z-index: 1;
  }

  /* ─── GOLD DIVIDER ─── */
  .gold-divider {
    width: 100%;
    overflow: visible;
    display: block;
    margin: 0;
    height: 48px;
    position: relative;
    z-index: 1;
  }

  /* ─── POST BODY ─── */
  .post-body {
    padding: 40px 72px 80px;
    position: relative;
    z-index: 1;
  }
  .prose {
    max-width: 720px;
    margin: 0 auto;
    text-align: left;
  }
  @media (min-width: 1100px) {
    .prose {
      max-width: 820px;
    }
  }
  @media (min-width: 1400px) {
    .prose {
      max-width: 900px;
    }
  }
  @media (min-width: 1700px) {
    .prose {
      max-width: 960px;
    }
  }

  /* ─── NEXT POST ─── */
  .next-post {
    padding: 40px 72px 96px;
    position: relative;
    z-index: 1;
  }
  .next-post-inner {
    max-width: 720px;
    margin: 0 auto;
    border: 1px solid rgba(156, 122, 62, 0.25);
    padding: 40px 44px;
    background: rgba(44, 58, 34, 0.03);
    transition: background 0.3s, border-color 0.3s;
  }
  @media (min-width: 1100px) {
    .next-post-inner { max-width: 820px; }
  }
  @media (min-width: 1400px) {
    .next-post-inner { max-width: 900px; }
  }
  @media (min-width: 1700px) {
    .next-post-inner { max-width: 960px; }
  }
  .next-post-inner:hover {
    background: rgba(44, 58, 34, 0.05);
    border-color: rgba(156, 122, 62, 0.45);
  }
  .next-post-label {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 10px;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: #9c7a3e;
    margin: 0 0 12px 0;
  }
  .next-post-link {
    font-family: var(--font-display);
    color: #2c3a22;
    font-size: clamp(20px, 2.4vw, 28px);
    font-weight: 500;
    line-height: 1.2;
    text-decoration: none;
    display: block;
    transition: color 0.2s;
  }
  .next-post-link:hover {
    color: #9c7a3e;
  }
  .next-post-link .arrow {
    color: #9c7a3e;
    margin-left: 8px;
    transition: margin-left 0.2s;
  }
  .next-post-link:hover .arrow {
    margin-left: 16px;
  }

  /* ─── ANIMATIONS ─── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(22px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.85s ease, transform 0.85s ease;
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 900px) {
    .post-hero {
      padding: 120px 24px 32px;
    }
    .hero-ghost {
      right: 16px;
      top: 80px;
    }
    .hero-content {
      flex-direction: column;
      align-items: flex-start;
      gap: 36px;
    }
    .hero-illustration {
      width: 320px;
      max-width: 80%;
      align-self: center;
    }
    .post-body {
      padding: 32px 24px 56px;
    }
    .next-post {
      padding: 32px 24px 72px;
    }
    .next-post-inner {
      padding: 28px 24px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .orb,
    .hero-illustration {
      animation: none;
    }
    .hero-label,
    .hero-title,
    .hero-byline,
    .hero-credit,
    .hero-ghost {
      opacity: 1;
      animation: none;
    }
    .reveal {
      opacity: 1;
      transform: none;
    }
  }
</style>

<!-- ─── PROSE (markdown content on cream) ─── -->
<style is:global>
  .skai-post .prose h2 {
    font-family: var(--font-display);
    color: #2c3a22;
    font-size: clamp(28px, 3.5vw, 40px);
    line-height: 1.15;
    font-weight: 600;
    margin: 3rem 0 1.5rem 0;
    letter-spacing: -0.01em;
  }
  .skai-post .prose h2 em {
    font-style: italic;
    color: #9c7a3e;
    font-weight: 600;
  }
  .skai-post .prose h3 {
    font-family: var(--font-display);
    color: #2c3a22;
    font-size: clamp(20px, 2.4vw, 24px);
    line-height: 1.25;
    font-weight: 500;
    margin: 2.25rem 0 0.75rem 0;
    opacity: 0.92;
  }
  .skai-post .prose p {
    font-family: var(--font-display);
    color: #2c3a22;
    font-size: clamp(18px, 1.7vw, 20px);
    line-height: 1.8;
    font-weight: 400;
    margin: 0 0 1.25rem 0;
  }
  .skai-post .prose p strong {
    font-weight: 600;
  }
  .skai-post .prose em {
    font-style: italic;
    color: #9c7a3e;
  }
  .skai-post .prose a {
    color: #2c3a22;
    text-decoration: underline;
    text-decoration-color: rgba(156, 122, 62, 0.5);
    text-underline-offset: 3px;
    transition: text-decoration-color 0.2s, color 0.2s;
  }
  .skai-post .prose a:hover {
    color: #9c7a3e;
    text-decoration-color: #9c7a3e;
  }

  /* EYEBROW (above H2) */
  .skai-post .prose .eyebrow {
    font-family: var(--font-body);
    font-weight: 400;
    font-style: normal;
    color: #9c7a3e;
    font-size: 11px;
    letter-spacing: 0.5em;
    text-transform: uppercase;
    margin: 3.25rem 0 0.5rem 0;
  }
  .skai-post .prose .eyebrow::before {
    content: "⋄ ";
    margin-right: 4px;
    opacity: 0.7;
  }
  .skai-post .prose .eyebrow + h2 {
    margin-top: 0.5rem;
  }

  /* PULL-QUOTE */
  .skai-post .prose blockquote {
    border-left: 2px solid #9c7a3e;
    padding: 0.75rem 0 0.75rem 1.75rem;
    margin: 1.25rem 0 2rem 0;
    border-radius: 0;
    background: none;
  }
  .skai-post .prose blockquote p {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(22px, 2.6vw, 28px);
    line-height: 1.45;
    font-weight: 400;
    color: #2c3a22;
    margin: 0;
  }
  .skai-post .prose blockquote p strong {
    font-weight: 500;
    color: #9c7a3e;
    font-style: italic;
  }

  /* METRICS BLOCK */
  .skai-post .prose .metrics {
    border-top: 1px solid rgba(44, 58, 34, 0.15);
    border-bottom: 1px solid rgba(44, 58, 34, 0.15);
    padding: 2rem 0;
    margin: 2rem 0 2.25rem 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }
  .skai-post .prose .metric-number {
    font-family: var(--font-display);
    font-weight: 600;
    color: #9c7a3e;
    font-size: clamp(36px, 4vw, 48px);
    line-height: 1;
    margin-bottom: 0.5rem;
    letter-spacing: -0.02em;
  }
  .skai-post .prose .metric-label {
    font-family: var(--font-body);
    font-weight: 500;
    color: #2c3a22;
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin-bottom: 0.45rem;
  }
  .skai-post .prose .metric-caveat {
    font-family: var(--font-display);
    font-style: italic;
    color: rgba(44, 58, 34, 0.65);
    font-size: 14px;
    line-height: 1.4;
  }

  @media (max-width: 768px) {
    .skai-post .prose h2 {
      margin: 2.25rem 0 1rem 0;
    }
    .skai-post .prose .metrics {
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem 1.25rem;
    }
    .skai-post .prose .eyebrow {
      font-size: 10px;
      letter-spacing: 0.4em;
      margin: 2.5rem 0 0.5rem 0;
    }
  }
</style>

---
import Layout from "./Layout.astro";

const { frontmatter } = Astro.props;

const formatDate = (d) => {
  const date = d instanceof Date ? d : new Date(d);
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
};

const plainTitle = frontmatter.title.replace(/<[^>]+>/g, "");
---

<Layout pageTitle={plainTitle} pageDescription={frontmatter.description}>

  <!-- ─── MASTHEAD ─── -->
  {frontmatter.series && (
    <div class="masthead">
      <div class="masthead-inner">
        {frontmatter.series}
        {frontmatter.part && (
          <>
            <span class="diamond">⋄</span>Part {frontmatter.part}
          </>
        )}
      </div>
    </div>
  )}

  <!-- ─── POST BODY ─── -->
  <article class="post-body">
    <div class="post-content">

      <h1 class="post-title" set:html={frontmatter.title} />

      <div class="byline">
        By {frontmatter.author}
        <span class="diamond">⋄</span>
        {formatDate(frontmatter.pubDate)}
        {frontmatter.readTime && (
          <>
            <span class="diamond">⋄</span>
            <span class="read-time">{frontmatter.readTime}</span>
          </>
        )}
      </div>

      {frontmatter.heroIllustration && (
        <figure class="hero-illustration">
          <img
            src={frontmatter.heroIllustration.url}
            alt={frontmatter.heroIllustration.alt}
          />
          {frontmatter.heroIllustration.caption && (
            <figcaption>{frontmatter.heroIllustration.caption}</figcaption>
          )}
        </figure>
      )}

      <div class="prose">
        <slot />
      </div>

    </div>

    {frontmatter.nextPart && (
      <aside class="next-post">
        <div class="next-post-inner">
          <div class="next-post-label">Next in the series</div>
          <a href={`/posts/${frontmatter.nextPart.slug}`} class="next-post-link">
            {frontmatter.nextPart.label} <span class="arrow">→</span>
          </a>
        </div>
      </aside>
    )}

    <div class="acknowledgment">
      Written with the editorial assistance of Claude (Anthropic).
    </div>
  </article>

</Layout>

<style is:global>
  /* ─── POST-SCOPED TOKENS (cream surface) ─── */
  .post-body {
    --text-primary: #2c3a22;
    --text-muted: rgba(44, 58, 34, 0.65);
    --text-subtle: rgba(44, 58, 34, 0.6);
    --text-whisper: rgba(44, 58, 34, 0.5);
    --border-subtle: rgba(44, 58, 34, 0.15);
    --border-whisper: rgba(44, 58, 34, 0.12);
    --next-post-bg: rgba(44, 58, 34, 0.04);
    --brown-gold: #9c7a3e;

    background: var(--cream);
  }
</style>

<style>
  /* ─── MASTHEAD ─── */
  .masthead {
    background: var(--olive);
    padding: 1.25rem 2.5rem;
  }
  .masthead-inner {
    max-width: 580px;
    margin: 0 auto;
    font-family: var(--font-body);
    color: var(--gold);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 2.5px;
    text-transform: uppercase;
  }
  .masthead .diamond {
    margin: 0 8px;
    opacity: 0.6;
  }

  @media (max-width: 768px) {
    .masthead {
      padding: 1rem 1.25rem;
    }
    .masthead-inner {
      font-size: 10px;
      letter-spacing: 2px;
    }
    .masthead .diamond {
      margin: 0 6px;
    }
  }

  /* ─── POST BODY ─── */
  .post-content {
    max-width: 580px;
    margin: 0 auto;
    padding: 3rem 2.5rem 2rem;
  }

  .post-title {
    font-family: var(--font-display);
    color: #2c3a22;
    font-size: 40px;
    line-height: 1.1;
    font-weight: 500;
    letter-spacing: -0.5px;
    margin: 0 0 1.25rem 0;
  }

  .post-title :global(em) {
    font-style: italic;
    color: #9c7a3e;
    font-weight: 500;
  }

  .byline {
    font-family: var(--font-body);
    color: rgba(44, 58, 34, 0.6);
    font-size: 13px;
    letter-spacing: 0.3px;
    margin-bottom: 2.5rem;
  }
  .byline .diamond {
    margin: 0 8px;
  }

  /* ─── HERO ILLUSTRATION ─── */
  .hero-illustration {
    margin: 0 0 2.5rem 0;
    text-align: center;
  }
  .hero-illustration img {
    max-width: 100%;
    width: 100%;
    height: auto;
    display: block;
  }
  .hero-illustration figcaption {
    font-family: var(--font-display);
    font-style: italic;
    color: rgba(44, 58, 34, 0.65);
    font-size: 14px;
    line-height: 1.4;
    margin-top: 1rem;
  }

  /* ─── NEXT POST ─── */
  .next-post {
    background: rgba(44, 58, 34, 0.04);
    border-top: 1px solid rgba(44, 58, 34, 0.12);
    padding: 2rem 2.5rem;
  }
  .next-post-inner {
    max-width: 580px;
    margin: 0 auto;
  }
  .next-post-label {
    font-family: var(--font-body);
    color: #2c3a22;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
    opacity: 0.6;
  }
  .next-post-link {
    font-family: var(--font-display);
    color: #2c3a22;
    font-size: 22px;
    font-weight: 500;
    line-height: 1.2;
    text-decoration: none;
    display: block;
    transition: color 0.2s;
  }
  .next-post-link:hover {
    color: #9c7a3e;
  }
  .next-post-link .arrow {
    color: #9c7a3e;
    margin-left: 4px;
  }

  /* ─── ACKNOWLEDGMENT ─── */
  .acknowledgment {
    font-family: var(--font-display);
    color: rgba(44, 58, 34, 0.5);
    font-size: 14px;
    font-style: italic;
    text-align: center;
    padding: 1.5rem 2.5rem 3rem;
  }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 768px) {
    .post-content {
      padding: 1.75rem 1.25rem 1.5rem;
    }
    .post-title {
      font-size: 28px;
      letter-spacing: -0.3px;
    }
    .byline {
      font-size: 12px;
      margin-bottom: 1.75rem;
    }
    .byline .diamond {
      margin: 0 6px;
    }
    .byline .read-time {
      display: none;
    }
    .next-post {
      padding: 1.5rem 1.25rem;
    }
    .next-post-label {
      font-size: 10px;
    }
    .next-post-link {
      font-size: 19px;
    }
    .acknowledgment {
      font-size: 13px;
      padding: 1.25rem 1.25rem 2rem;
    }
  }

  /* ─── DESKTOP — widen reading column and elements ─── */
  @media (min-width: 900px) {
    .post-content {
      max-width: 760px;
      padding: 4rem 3rem 2.5rem;
    }
    .post-title {
      font-size: 52px;
      line-height: 1.05;
      letter-spacing: -0.8px;
      margin-bottom: 1.5rem;
    }
    .byline {
      font-size: 14px;
      margin-bottom: 3rem;
    }
    .hero-illustration {
      margin-bottom: 3rem;
    }
    .masthead-inner {
      max-width: 760px;
    }
    .next-post {
      padding: 2.5rem 3rem;
    }
    .next-post-inner {
      max-width: 760px;
    }
    .next-post-link {
      font-size: 26px;
    }
    .acknowledgment {
      font-size: 15px;
      padding: 2rem 3rem 3.5rem;
    }
  }

  @media (min-width: 1200px) {
    .post-content {
      max-width: 880px;
      padding: 5rem 4rem 3rem;
    }
    .post-title {
      font-size: 60px;
      letter-spacing: -1px;
    }
    .masthead-inner,
    .next-post-inner {
      max-width: 880px;
    }
    .hero-illustration {
      margin-left: -40px;
      margin-right: -40px;
    }
  }

  @media (min-width: 1600px) {
    .post-content {
      max-width: 960px;
      padding: 6rem 4rem 3.5rem;
    }
    .post-title {
      font-size: 68px;
      letter-spacing: -1.2px;
    }
    .masthead-inner,
    .next-post-inner {
      max-width: 960px;
    }
    .hero-illustration {
      margin-left: -60px;
      margin-right: -60px;
    }
  }
</style>

<!-- Prose styles applied to markdown content via .prose — global so they reach rendered content -->
<style is:global>
  .prose h2 {
    font-family: var(--font-display);
    color: #2c3a22;
    font-size: 26px;
    line-height: 1.15;
    font-weight: 500;
    margin: 2rem 0 1.25rem 0;
  }
  .prose h2 em {
    font-style: italic;
    color: #9c7a3e;
    font-weight: 500;
  }
  .prose h3 {
    font-family: var(--font-display);
    color: #2c3a22;
    font-size: 20px;
    line-height: 1.25;
    font-weight: 500;
    opacity: 0.85;
    margin: 1.75rem 0 0.75rem 0;
  }
  .prose p {
    font-family: var(--font-display);
    color: #2c3a22;
    font-size: 19px;
    line-height: 1.55;
    font-weight: 400;
    margin: 0 0 1rem 0;
  }
  .prose p strong {
    font-weight: 500;
  }
  .prose em {
    font-style: italic;
    color: #9c7a3e;
  }
  .prose a {
    color: #2c3a22;
    text-decoration: underline;
    text-decoration-color: rgba(156, 122, 62, 0.5);
    text-underline-offset: 3px;
    transition: text-decoration-color 0.2s;
  }
  .prose a:hover {
    text-decoration-color: #9c7a3e;
  }

  /* ─── EYEBROW (italic serif label before H2) ─── */
  .prose .eyebrow {
    font-family: var(--font-display);
    font-style: italic;
    color: #2c3a22;
    font-size: 16px;
    letter-spacing: 0.5px;
    margin: 2.5rem 0 0.35rem 0;
  }
  .prose .eyebrow::before {
    content: "⋄";
    color: #9c7a3e;
    margin-right: 8px;
    font-style: normal;
  }
  .prose .eyebrow + h2 {
    margin-top: 0;
  }

  /* ─── PULL-QUOTE (blockquote) ─── */
  .prose blockquote {
    border-left: 2px solid #9c7a3e;
    padding: 0.5rem 0 0.5rem 1.25rem;
    margin: 0.5rem 0 1.5rem 0;
    border-radius: 0;
    background: none;
  }
  .prose blockquote p {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 21px;
    line-height: 1.45;
    font-weight: 400;
    color: #2c3a22;
    margin: 0;
  }
  .prose blockquote p strong {
    font-weight: 500;
    font-style: italic;
  }

  /* ─── METRICS BLOCK ─── */
  .prose .metrics {
    border-top: 1px solid rgba(44, 58, 34, 0.15);
    border-bottom: 1px solid rgba(44, 58, 34, 0.15);
    padding: 1.75rem 0;
    margin: 1.5rem 0 1.75rem 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }
  .prose .metric-number {
    font-family: var(--font-body);
    color: #9c7a3e;
    font-size: 34px;
    font-weight: 400;
    line-height: 1;
    margin-bottom: 0.4rem;
  }
  .prose .metric-label {
    font-family: var(--font-body);
    color: #2c3a22;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    margin-bottom: 0.35rem;
  }
  .prose .metric-caveat {
    font-family: var(--font-display);
    color: rgba(44, 58, 34, 0.65);
    font-size: 13px;
    line-height: 1.4;
    font-style: italic;
  }

  @media (max-width: 768px) {
    .prose h2 {
      font-size: 22px;
      line-height: 1.2;
    }
    .prose p {
      font-size: 17px;
      line-height: 1.6;
    }
    .prose .eyebrow {
      font-size: 14px;
      letter-spacing: 0.4px;
    }
    .prose .eyebrow::before {
      margin-right: 6px;
    }
    .prose blockquote p {
      font-size: 18px;
    }
    .prose blockquote {
      padding: 0.35rem 0 0.35rem 1rem;
    }
    .prose .metrics {
      grid-template-columns: 1fr 1fr;
      gap: 1.25rem 1rem;
      padding: 1.25rem 0 1rem;
    }
    .prose .metric-number {
      font-size: 28px;
    }
    .prose .metric-label {
      font-size: 10px;
    }
    .prose .metric-caveat {
      font-size: 12px;
    }
  }

  /* ─── DESKTOP — larger prose on bigger screens ─── */
  @media (min-width: 900px) {
    .prose h2 {
      font-size: 30px;
      line-height: 1.15;
      margin: 2.5rem 0 1.5rem 0;
    }
    .prose h3 {
      font-size: 22px;
      margin: 2rem 0 1rem 0;
    }
    .prose p {
      font-size: 20px;
      line-height: 1.65;
      margin-bottom: 1.25rem;
    }
    .prose .eyebrow {
      font-size: 16px;
      margin: 3rem 0 0.5rem 0;
    }
    .prose blockquote {
      padding: 0.75rem 0 0.75rem 1.5rem;
      margin: 1rem 0 2rem 0;
    }
    .prose blockquote p {
      font-size: 23px;
      line-height: 1.45;
    }
    .prose .metrics {
      padding: 2rem 0;
      margin: 2rem 0 2.25rem 0;
      gap: 1.5rem;
    }
    .prose .metric-number {
      font-size: 40px;
    }
    .prose .metric-label {
      font-size: 12px;
    }
    .prose .metric-caveat {
      font-size: 14px;
    }
  }

  @media (min-width: 1200px) {
    .prose h2 {
      font-size: 36px;
    }
    .prose h3 {
      font-size: 24px;
    }
    .prose p {
      font-size: 21px;
      line-height: 1.7;
    }
    .prose blockquote p {
      font-size: 26px;
    }
    .prose .metrics {
      margin-left: -40px;
      margin-right: -40px;
      padding: 2.25rem 0;
    }
    .prose .metric-number {
      font-size: 46px;
    }
  }

  @media (min-width: 1600px) {
    .prose h2 {
      font-size: 40px;
    }
    .prose p {
      font-size: 22px;
    }
    .prose blockquote p {
      font-size: 28px;
    }
    .prose .metrics {
      margin-left: -60px;
      margin-right: -60px;
    }
    .prose .metric-number {
      font-size: 52px;
    }
  }
</style>

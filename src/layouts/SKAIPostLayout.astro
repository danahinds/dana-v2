---
import Layout from "./Layout.astro";

const { frontmatter } = Astro.props;

const formatDate = (d) => {
  const date = d instanceof Date ? d : new Date(d);
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
};

const plainTitle = frontmatter.title.replace(/<[^>]+>/g, "");
const partLabel = frontmatter.part ? String(frontmatter.part).padStart(2, "0") : null;
---

<Layout pageTitle={plainTitle} pageDescription={frontmatter.description}>

  <!-- ORB LAYER -->
  <div class="orb-layer">
    <div class="orb orb-a"></div>
    <div class="orb orb-b"></div>
    <div class="orb orb-c"></div>
    <div class="orb orb-d"></div>
    <div class="orb orb-e"></div>
  </div>

  <article class="skai-post">

    <!-- HERO -->
    <section class="post-hero">
      {partLabel && <div class="hero-ghost">{partLabel}</div>}

      <div class="hero-content">
        <div class="hero-text">
          {frontmatter.series && (
            <p class="hero-label">
              {frontmatter.series}
              {frontmatter.part && <> <span class="divider">·</span> Part {frontmatter.part}</>}
            </p>
          )}
          <h1 class="hero-title" set:html={frontmatter.title} />
          <p class="hero-byline">
            By {frontmatter.author}
            <span class="divider">·</span>
            {formatDate(frontmatter.pubDate)}
            {frontmatter.readTime && (
              <>
                <span class="divider">·</span>
                <span class="read-time">{frontmatter.readTime}</span>
              </>
            )}
          </p>
        </div>

        {frontmatter.heroIllustration && (
          <div class="hero-illustration">
            <img
              src={frontmatter.heroIllustration.url}
              alt={frontmatter.heroIllustration.alt}
            />
          </div>
        )}
      </div>
    </section>

    {frontmatter.heroIllustration?.caption && (
      <p class="hero-caption">{frontmatter.heroIllustration.caption}</p>
    )}

    <!-- GOLD DIVIDER -->
    <svg class="gold-divider" viewBox="0 0 1440 48" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0 24 Q180 4 360 24 T720 24 T1080 24 T1440 24" fill="none" stroke="rgba(200,164,90,0.35)" stroke-width="1"/>
      <path d="M0 32 Q240 48 480 28 T960 32 T1440 28" fill="none" stroke="rgba(226,192,122,0.15)" stroke-width="0.75"/>
      <circle cx="360" cy="24" r="3" fill="rgba(200,164,90,0.5)"/>
      <circle cx="720" cy="24" r="2" fill="rgba(200,164,90,0.4)"/>
      <circle cx="1080" cy="24" r="3" fill="rgba(200,164,90,0.5)"/>
    </svg>

    <!-- POST BODY -->
    <section class="post-body reveal">
      <div class="prose">
        <slot />
      </div>
    </section>

    <!-- GOLD DIVIDER -->
    <svg class="gold-divider" viewBox="0 0 1440 48" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <line x1="72" y1="24" x2="400" y2="24" stroke="rgba(200,164,90,0.4)" stroke-width="0.75"/>
      <circle cx="400" cy="24" r="2.5" fill="none" stroke="rgba(200,164,90,0.5)" stroke-width="1"/>
      <line x1="406" y1="24" x2="700" y2="24" stroke="rgba(200,164,90,0.2)" stroke-width="0.5" stroke-dasharray="4 6"/>
      <circle cx="700" cy="24" r="1.5" fill="rgba(200,164,90,0.4)"/>
      <line x1="706" y1="24" x2="1040" y2="24" stroke="rgba(200,164,90,0.2)" stroke-width="0.5" stroke-dasharray="4 6"/>
      <circle cx="1040" cy="24" r="2.5" fill="none" stroke="rgba(200,164,90,0.5)" stroke-width="1"/>
      <line x1="1046" y1="24" x2="1370" y2="24" stroke="rgba(200,164,90,0.4)" stroke-width="0.75"/>
    </svg>

    <!-- NEXT POST -->
    {frontmatter.nextPart && (
      <aside class="next-post">
        <div class="next-post-inner">
          <p class="next-post-label">Next in the series</p>
          <a href={`/posts/${frontmatter.nextPart.slug}`} class="next-post-link">
            {frontmatter.nextPart.label} <span class="arrow">→</span>
          </a>
        </div>
      </aside>
    )}

    <!-- ACKNOWLEDGMENT -->
    <p class="acknowledgment">
      Written with the editorial assistance of Claude (Anthropic).
    </p>

  </article>

</Layout>

<script>
  function initPost() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.05 });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
    setTimeout(() => {
      document.querySelectorAll('.reveal:not(.visible)').forEach(el => el.classList.add('visible'));
    }, 3000);
  }
  document.addEventListener('astro:page-load', initPost);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPost);
  } else {
    initPost();
  }
</script>

<style>
  /* ─── ORB LAYER ─── */
  .orb-layer {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }
  .orb {
    position: absolute;
    border-radius: 50%;
  }
  .orb-a {
    width: 300px; height: 300px; top: 10vh; left: 5vw;
    background: radial-gradient(circle, rgba(200,164,90,0.14) 0%, transparent 70%);
    animation: floatOrb 9s ease-in-out infinite;
  }
  .orb-b {
    width: 200px; height: 200px; top: 35vh; right: 6vw;
    background: radial-gradient(circle, rgba(226,192,122,0.18) 0%, transparent 70%);
    animation: floatOrb 12s ease-in-out 1.5s infinite;
  }
  .orb-c {
    width: 140px; height: 140px; top: 60vh; left: 20vw;
    background: radial-gradient(circle, rgba(200,164,90,0.20) 0%, transparent 70%);
    animation: floatOrb 7s ease-in-out 3s infinite;
  }
  .orb-d {
    width: 90px; height: 90px; top: 75vh; right: 25vw;
    background: radial-gradient(circle, rgba(226,192,122,0.22) 0%, transparent 70%);
    animation: floatOrb 10s ease-in-out 0.8s infinite;
  }
  .orb-e {
    width: 240px; height: 240px; bottom: 10vh; right: 4vw;
    background: radial-gradient(circle, rgba(200,164,90,0.12) 0%, transparent 70%);
    animation: floatOrb 14s ease-in-out 2s infinite;
  }
  @keyframes floatOrb {
    0%, 100% { transform: translateY(0) scale(1); }
    50% { transform: translateY(-30px) scale(1.06); }
  }

  /* ─── POST SHELL ─── */
  .skai-post {
    position: relative;
    z-index: 1;
  }

  /* ─── HERO ─── */
  .post-hero {
    padding: 160px 72px 40px;
    position: relative;
    overflow: hidden;
  }

  .hero-ghost {
    position: absolute;
    right: 48px;
    top: 110px;
    font-family: var(--font-display);
    font-weight: 600;
    font-style: italic;
    font-size: clamp(120px, 20vw, 260px);
    color: transparent;
    -webkit-text-stroke: 1px rgba(200,164,90,0.10);
    pointer-events: none;
    user-select: none;
    line-height: 1;
    opacity: 0;
    animation: fadeIn 1.4s ease 0.9s forwards;
  }

  .hero-content {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 48px;
    max-width: 1400px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .hero-text {
    flex: 1;
    min-width: 0;
  }

  .hero-label {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 11px;
    letter-spacing: 0.5em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 28px;
    opacity: 0;
    animation: fadeUp 0.9s ease 0.1s forwards;
  }
  .hero-label .divider {
    margin: 0 8px;
    opacity: 0.6;
  }

  .hero-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(44px, 7vw, 96px);
    line-height: 1.0;
    letter-spacing: -0.02em;
    color: var(--cream);
    margin: 0 0 32px 0;
    opacity: 0;
    animation: fadeUp 0.9s ease 0.25s forwards;
  }
  .hero-title :global(em) {
    font-style: italic;
    color: var(--gold-light);
  }

  .hero-byline {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 13px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin: 0;
    opacity: 0;
    animation: fadeUp 0.9s ease 0.45s forwards;
  }
  .hero-byline .divider {
    margin: 0 10px;
    opacity: 0.5;
  }

  /* ─── HERO ILLUSTRATION ─── */
  .hero-illustration {
    flex-shrink: 0;
    width: 480px;
    max-width: 40vw;
    filter: drop-shadow(0 0 50px rgba(200,164,90,0.3));
    animation: illuFloat 7s ease-in-out infinite;
    opacity: 0;
    animation: fadeIn 1s ease 0.5s forwards, illuFloat 7s ease-in-out 1.5s infinite;
  }
  .hero-illustration img {
    width: 100%;
    display: block;
    border-radius: 4px;
  }
  @keyframes illuFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-16px); }
  }

  .hero-caption {
    font-family: var(--font-display);
    font-style: italic;
    text-align: center;
    color: var(--text-muted);
    font-size: 15px;
    line-height: 1.5;
    max-width: 640px;
    margin: 0 auto 24px;
    padding: 0 32px;
    position: relative;
    z-index: 1;
  }

  /* ─── GOLD DIVIDER ─── */
  .gold-divider {
    width: 100%;
    overflow: visible;
    display: block;
    margin: 0;
    height: 48px;
    position: relative;
    z-index: 1;
  }

  /* ─── POST BODY ─── */
  .post-body {
    padding: 40px 72px 80px;
    position: relative;
    z-index: 1;
  }

  .prose {
    max-width: 720px;
    margin: 0 auto;
  }

  /* ─── NEXT POST ─── */
  .next-post {
    padding: 56px 72px;
    max-width: 900px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }
  .next-post-inner {
    border: 1px solid rgba(200, 164, 90, 0.18);
    padding: 40px 44px;
    background: rgba(200, 164, 90, 0.04);
    transition: background 0.3s, border-color 0.3s;
  }
  .next-post-inner:hover {
    background: rgba(200, 164, 90, 0.08);
    border-color: rgba(200, 164, 90, 0.35);
  }
  .next-post-label {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 10px;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--gold);
    margin: 0 0 12px 0;
  }
  .next-post-link {
    font-family: var(--font-display);
    color: var(--cream);
    font-size: clamp(20px, 2.4vw, 28px);
    font-weight: 500;
    line-height: 1.2;
    text-decoration: none;
    display: block;
    transition: color 0.2s;
  }
  .next-post-link:hover {
    color: var(--gold-light);
  }
  .next-post-link .arrow {
    color: var(--gold);
    margin-left: 8px;
    transition: margin-left 0.2s;
  }
  .next-post-link:hover .arrow {
    margin-left: 16px;
  }

  /* ─── ACKNOWLEDGMENT ─── */
  .acknowledgment {
    font-family: var(--font-display);
    font-style: italic;
    text-align: center;
    color: rgba(245, 240, 232, 0.4);
    font-size: 14px;
    padding: 32px 24px 96px;
    position: relative;
    z-index: 1;
  }

  /* ─── ANIMATIONS ─── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(22px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.85s ease, transform 0.85s ease;
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 900px) {
    .post-hero {
      padding: 120px 24px 32px;
    }
    .hero-ghost {
      right: 16px;
      top: 80px;
    }
    .hero-content {
      flex-direction: column;
      align-items: flex-start;
      gap: 36px;
    }
    .hero-illustration {
      width: 320px;
      max-width: 80%;
      align-self: center;
    }
    .post-body {
      padding: 32px 24px 56px;
    }
    .next-post {
      padding: 40px 24px;
    }
    .next-post-inner {
      padding: 28px 24px;
    }
    .acknowledgment {
      padding: 24px 24px 72px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .orb,
    .hero-illustration {
      animation: none;
    }
    .hero-label,
    .hero-title,
    .hero-byline,
    .hero-ghost {
      opacity: 1;
      animation: none;
    }
    .reveal {
      opacity: 1;
      transform: none;
    }
  }
</style>

<!-- ─── PROSE (markdown content on olive) ─── -->
<style is:global>
  .skai-post .prose h2 {
    font-family: var(--font-display);
    color: var(--cream);
    font-size: clamp(28px, 3.5vw, 40px);
    line-height: 1.15;
    font-weight: 600;
    margin: 3rem 0 1.5rem 0;
    letter-spacing: -0.01em;
  }
  .skai-post .prose h2 em {
    font-style: italic;
    color: var(--gold-light);
    font-weight: 600;
  }
  .skai-post .prose h3 {
    font-family: var(--font-display);
    color: var(--cream);
    font-size: clamp(20px, 2.4vw, 24px);
    line-height: 1.25;
    font-weight: 500;
    margin: 2.25rem 0 0.75rem 0;
    opacity: 0.92;
  }
  .skai-post .prose p {
    font-family: var(--font-display);
    color: var(--text-muted);
    font-size: clamp(18px, 1.7vw, 20px);
    line-height: 1.85;
    font-weight: 400;
    margin: 0 0 1.25rem 0;
  }
  .skai-post .prose p strong {
    font-weight: 600;
    color: var(--cream);
  }
  .skai-post .prose em {
    font-style: italic;
    color: var(--gold-light);
  }
  .skai-post .prose a {
    color: var(--cream);
    text-decoration: underline;
    text-decoration-color: rgba(200, 164, 90, 0.5);
    text-underline-offset: 3px;
    transition: text-decoration-color 0.2s, color 0.2s;
  }
  .skai-post .prose a:hover {
    color: var(--gold-light);
    text-decoration-color: var(--gold-light);
  }

  /* EYEBROW (above H2) */
  .skai-post .prose .eyebrow {
    font-family: var(--font-body);
    font-weight: 400;
    font-style: normal;
    color: var(--gold);
    font-size: 11px;
    letter-spacing: 0.5em;
    text-transform: uppercase;
    margin: 3.25rem 0 0.5rem 0;
  }
  .skai-post .prose .eyebrow::before {
    content: "⋄ ";
    margin-right: 4px;
    opacity: 0.7;
  }
  .skai-post .prose .eyebrow + h2 {
    margin-top: 0.5rem;
  }

  /* PULL-QUOTE */
  .skai-post .prose blockquote {
    border-left: 2px solid var(--gold);
    padding: 0.75rem 0 0.75rem 1.75rem;
    margin: 1.25rem 0 2rem 0;
    border-radius: 0;
    background: none;
  }
  .skai-post .prose blockquote p {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(22px, 2.6vw, 28px);
    line-height: 1.45;
    font-weight: 400;
    color: var(--gold-light);
    margin: 0;
  }
  .skai-post .prose blockquote p strong {
    font-weight: 500;
    color: var(--cream);
    font-style: italic;
  }

  /* METRICS BLOCK */
  .skai-post .prose .metrics {
    border-top: 1px solid rgba(200, 164, 90, 0.18);
    border-bottom: 1px solid rgba(200, 164, 90, 0.18);
    padding: 2rem 0;
    margin: 2rem 0 2.25rem 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }
  .skai-post .prose .metric-number {
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--gold);
    font-size: clamp(36px, 4vw, 48px);
    line-height: 1;
    margin-bottom: 0.5rem;
    letter-spacing: -0.02em;
  }
  .skai-post .prose .metric-label {
    font-family: var(--font-body);
    font-weight: 500;
    color: var(--cream);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin-bottom: 0.45rem;
  }
  .skai-post .prose .metric-caveat {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--text-muted);
    font-size: 14px;
    line-height: 1.4;
  }

  @media (max-width: 768px) {
    .skai-post .prose h2 {
      margin: 2.25rem 0 1rem 0;
    }
    .skai-post .prose .metrics {
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem 1.25rem;
    }
    .skai-post .prose .eyebrow {
      font-size: 10px;
      letter-spacing: 0.4em;
      margin: 2.5rem 0 0.5rem 0;
    }
  }
</style>

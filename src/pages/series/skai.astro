---
import Layout from "../../layouts/Layout.astro";

const episodes = [
  {
    part: 1,
    eyebrow: "Episode · Published",
    title: "The problem that led to The Playground",
    description: "A volunteer project took on a life of its own, and scaling it into SaaS required solving a UX testing problem that didn't have an off-the-shelf answer.",
    status: "published",
    href: "/posts/playground-part-1",
  },
  {
    part: 2,
    eyebrow: "Episode · Coming soon",
    title: null,
    description: null,
    status: "coming-soon",
    href: null,
  },
  {
    part: 3,
    eyebrow: "Episode · Coming soon",
    title: null,
    description: null,
    status: "coming-soon",
    href: null,
  },
  {
    part: 4,
    eyebrow: "Episode · Coming soon",
    title: null,
    description: null,
    status: "coming-soon",
    href: null,
  },
  {
    part: 5,
    eyebrow: "Episode · Coming soon",
    title: null,
    description: null,
    status: "coming-soon",
    href: null,
  },
];
---

<Layout pageTitle="SKAI is the Limit? — A Series by Dana Sandy" pageDescription="We gave AI a development team and one mission — to build a real app from scratch. Does SKAI have a limit?">

  <!-- HERO -->
  <section class="hero">
    <div class="hero-ghost">Series</div>
    <p class="hero-label">A Series · Five Parts</p>
    <h1 class="hero-name">SKAI is the <em>Limit?</em></h1>
    <div class="hero-intro">
      <p class="hero-lede">SKAI is my journey as a Product Manager, challenging myself to build with <em>AI.</em></p>
      <p class="hero-body">Through a series of experiments, I explore what it means to execute with AI in real situations. I look at how decisions are made, where AI fits, and where human judgment still matters.</p>
      <p class="hero-body">In one series, I experiment with building alongside AI skills and agents, treating AI like a development team and asking a simple question: <em>what happens when AI is given a clear mission to build a real app from scratch?</em></p>
    </div>
    <p class="hero-meta"><span class="hero-meta-num">5</span> episodes &middot; <span class="hero-meta-num">~5 min</span> each &middot; Launching soon</p>
  </section>

  <!-- GOLD DIVIDER -->
  <svg class="gold-divider" viewBox="0 0 1440 48" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
    <line x1="72" y1="24" x2="400" y2="24" stroke="rgba(200,164,90,0.4)" stroke-width="0.75"/>
    <circle cx="400" cy="24" r="2.5" fill="none" stroke="rgba(200,164,90,0.5)" stroke-width="1"/>
    <line x1="406" y1="24" x2="700" y2="24" stroke="rgba(200,164,90,0.2)" stroke-width="0.5" stroke-dasharray="4 6"/>
    <circle cx="700" cy="24" r="1.5" fill="rgba(200,164,90,0.4)"/>
    <line x1="706" y1="24" x2="1040" y2="24" stroke="rgba(200,164,90,0.2)" stroke-width="0.5" stroke-dasharray="4 6"/>
    <circle cx="1040" cy="24" r="2.5" fill="none" stroke="rgba(200,164,90,0.5)" stroke-width="1"/>
    <line x1="1046" y1="24" x2="1370" y2="24" stroke="rgba(200,164,90,0.4)" stroke-width="0.75"/>
  </svg>

  {episodes.map((ep, i) => (
    <>
      <article class={`chapter reveal ${ep.status === "coming-soon" ? "chapter-soon" : ""}`} data-chapter={String(ep.part).padStart(2, "0")}>
        <div class="chapter-head">
          <span class="chapter-num">{String(ep.part).padStart(2, "0")}</span>
          <p class="chapter-eyebrow">{ep.eyebrow}</p>
        </div>

        {ep.title ? (
          <>
            <h2 class="chapter-title">{ep.title}</h2>
            {ep.description && <p class="chapter-hook">{ep.description}</p>}
            <p class="chapter-cta-eyebrow">Read time &middot; <span class="chapter-cta-eyebrow-num">~5 min</span></p>
            <hr class="chapter-cta-rule" />
            <div class="chapter-cta-list">
              <a class="chapter-cta-item" href={ep.href}>
                <span class="chapter-cta-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4.5A2.5 2.5 0 0 1 6.5 2H20v18H6.5A2.5 2.5 0 0 0 4 22.5z"/><path d="M4 4.5A2.5 2.5 0 0 0 6.5 7H20"/></svg>
                </span>
                <span class="chapter-cta-text">Read the episode</span>
                <span class="chapter-cta-arrow" aria-hidden="true">&rarr;</span>
              </a>
            </div>
          </>
        ) : (
          <p class="chapter-soon-line"><em>Title coming soon.</em> The story is still being written.</p>
        )}
      </article>

      {i < episodes.length - 1 && (
        <div class="chapter-break" aria-hidden="true">
          <span></span><span class="dot"></span><span></span>
        </div>
      )}
    </>
  ))}

  <!-- WHY THIS SERIES — block centered on page, paragraphs read left-aligned -->
  <section class="why-block reveal">
    <p class="eyebrow">Why this series</p>
    <h2 class="why-headline">A record of building with AI, <em>honestly.</em></h2>
    <p class="why-text">Not a tutorial. Not a pitch. A closer look at where AI tools accelerate real work — and where they still need a human to notice what matters.</p>
    <div class="why-cta-row">
      <a href="/contact" class="why-cta">Get in touch &rarr;</a>
      <a href="/work" class="why-cta-secondary">See my work &rarr;</a>
    </div>
  </section>

</Layout>

<script>
  function initSkaiPage() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.05 });

    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

    setTimeout(() => {
      document.querySelectorAll('.reveal:not(.visible)').forEach(el => el.classList.add('visible'));
    }, 3000);
  }
  document.addEventListener('astro:page-load', initSkaiPage);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSkaiPage);
  } else {
    initSkaiPage();
  }
</script>

<style>
  /* ─── HERO ─── */
  .hero {
    padding: 160px 72px 80px;
    position: relative;
    z-index: 1;
  }

  .hero-label {
    font-family: var(--font-body);
    font-weight: var(--weight-light);
    font-size: var(--text-2xs);
    letter-spacing: 0.55em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 24px;
    opacity: 0;
    animation: fadeUp 0.9s ease 0.1s forwards;
  }

  .hero-name {
    font-family: var(--font-display);
    font-weight: var(--weight-semibold);
    font-size: clamp(56px, 10vw, 130px);
    line-height: 0.9;
    letter-spacing: var(--tracking-tight);
    color: var(--cream);
    opacity: 0;
    animation: fadeUp 0.9s ease 0.25s forwards;
  }

  .hero-name em {
    font-style: italic;
    color: var(--gold-light);
  }

  .hero-intro {
    margin-top: 36px;
    max-width: 720px;
    opacity: 0;
    animation: fadeUp 0.9s ease 0.5s forwards;
  }

  .hero-lede {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(22px, 2.6vw, 30px);
    line-height: var(--leading-relaxed);
    color: var(--cream);
    margin: 0 0 24px;
  }

  .hero-lede em {
    color: var(--gold-light);
  }

  .hero-body {
    font-family: var(--font-display);
    font-size: clamp(17px, 1.8vw, 20px);
    line-height: var(--leading-loose);
    color: var(--cream);
    margin: 0 0 18px;
  }

  .hero-body:last-child {
    margin-bottom: 0;
  }

  .hero-body em {
    font-style: italic;
    color: var(--gold-light);
  }

  .hero-meta {
    margin-top: 36px;
    padding-top: 18px;
    border-top: 1px solid rgba(200, 164, 90, 0.18);
    max-width: 720px;
    font-family: var(--font-body);
    font-size: var(--text-2xs);
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--text-muted);
    opacity: 0;
    animation: fadeUp 0.9s ease 0.7s forwards;
  }

  .hero-meta-num {
    color: var(--gold);
    font-weight: var(--weight-medium);
  }

  .hero-ghost {
    position: absolute;
    right: 40px;
    top: 110px;
    font-family: var(--font-display);
    font-weight: var(--weight-semibold);
    font-style: italic;
    font-size: clamp(100px, 18vw, 200px);
    color: transparent;
    -webkit-text-stroke: 1px rgba(200,164,90,0.10);
    pointer-events: none;
    user-select: none;
    opacity: 0;
    animation: fadeIn 1.4s ease 0.9s forwards;
  }

  /* ─── GOLD DIVIDER ─── */
  .gold-divider {
    width: 100%;
    overflow: visible;
    display: block;
    margin: 0;
    height: 48px;
    position: relative;
    z-index: 1;
  }

  /* ─── CHAPTER (matches My Work pattern) ─── */
  .chapter {
    max-width: 920px;
    margin: 0 auto;
    padding: 96px 72px 72px;
    position: relative;
    z-index: 1;
  }

  .chapter-soon {
    padding-top: 64px;
    padding-bottom: 56px;
    opacity: 0.78;
  }

  .chapter-head {
    display: flex;
    align-items: baseline;
    gap: 28px;
    margin-bottom: 18px;
  }

  .chapter-num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: var(--weight-light);
    font-size: clamp(56px, 8vw, 96px);
    line-height: 1;
    color: var(--gold);
    letter-spacing: var(--tracking-tight);
    flex-shrink: 0;
  }

  .chapter-soon .chapter-num {
    color: var(--text-muted);
  }

  .chapter-eyebrow {
    font-family: var(--font-body);
    font-weight: var(--weight-regular);
    font-size: var(--text-2xs);
    letter-spacing: 0.45em;
    text-transform: uppercase;
    color: var(--gold);
    line-height: 1.4;
  }

  .chapter-soon .chapter-eyebrow {
    color: var(--text-muted);
  }

  .chapter-title {
    font-family: var(--font-display);
    font-weight: var(--weight-light);
    font-size: clamp(36px, 5.5vw, 60px);
    line-height: 1.05;
    color: var(--cream);
    margin: 0 0 24px;
    letter-spacing: var(--tracking-tight);
  }

  .chapter-title em {
    font-style: italic;
    color: var(--gold-light);
  }

  .chapter-hook {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(20px, 2.2vw, 26px);
    line-height: var(--leading-relaxed);
    color: var(--cream);
    max-width: 720px;
    margin: 0 0 40px;
  }

  /* Eyebrow + full-width thin gold rule that introduces the CTA list */
  .chapter-cta-eyebrow {
    font-family: var(--font-body);
    font-weight: var(--weight-regular);
    font-size: var(--text-2xs);
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin: 0 0 14px;
  }

  .chapter-cta-eyebrow-num {
    color: var(--gold);
    font-weight: var(--weight-medium);
  }

  .chapter-cta-rule {
    border: none;
    border-top: 1px solid rgba(200, 164, 90, 0.35);
    margin: 0 0 16px;
  }

  /* "Coming soon" placeholder line for unwritten episodes */
  .chapter-soon-line {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(17px, 1.8vw, 20px);
    line-height: var(--leading-relaxed);
    color: var(--text-muted);
    margin: 8px 0 0;
  }
  .chapter-soon-line em {
    color: var(--gold-light);
  }

  /* ─── CHAPTER CTA LIST (matches My Work) ─── */
  .chapter-cta-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-top: 0;
  }

  .chapter-cta-item {
    display: flex;
    align-items: center;
    gap: 18px;
    text-decoration: none;
    color: var(--cream);
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(20px, 2.2vw, 26px);
    line-height: 1.3;
    padding: 14px 0;
    border-bottom: 1px solid rgba(200, 164, 90, 0.18);
    transition: color 0.25s, border-color 0.25s, padding 0.25s;
  }

  .chapter-cta-item:last-child {
    border-bottom: none;
  }

  .chapter-cta-icon {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--gold);
    transition: color 0.25s, transform 0.25s;
  }

  .chapter-cta-icon svg {
    width: 100%;
    height: 100%;
  }

  .chapter-cta-text {
    flex: 1;
    color: var(--gold-light);
  }

  .chapter-cta-arrow {
    color: var(--gold);
    font-style: normal;
    font-size: 22px;
    line-height: 1;
    transition: transform 0.3s ease, color 0.25s;
  }

  .chapter-cta-item:hover {
    border-color: var(--gold-light);
  }

  .chapter-cta-item:hover .chapter-cta-text {
    color: var(--cream);
  }

  .chapter-cta-item:hover .chapter-cta-icon {
    color: var(--gold-light);
    transform: scale(1.1);
  }

  .chapter-cta-item:hover .chapter-cta-arrow {
    transform: translateX(6px);
    color: var(--gold-light);
  }

  /* ─── CHAPTER BREAK ─── */
  .chapter-break {
    max-width: 920px;
    margin: 0 auto;
    padding: 0 72px;
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .chapter-break span {
    flex: 1;
    height: 1px;
    background: rgba(200, 164, 90, 0.18);
  }

  .chapter-break .dot {
    flex: none;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--gold);
    opacity: 0.6;
  }

  /* ─── WHY BLOCK — block centered on page, prose left-aligned ─── */
  .why-block {
    max-width: 920px;
    margin: 64px auto 0;
    padding: 80px 72px 120px;
    border-top: 1px solid rgba(200, 164, 90, 0.18);
    position: relative;
    z-index: 1;
  }

  .why-block .eyebrow {
    font-family: var(--font-body);
    font-weight: var(--weight-regular);
    font-size: var(--text-2xs);
    letter-spacing: 0.45em;
    text-transform: uppercase;
    color: var(--gold);
    margin: 0 auto 20px;
    max-width: 620px;
  }

  .why-headline {
    font-family: var(--font-display);
    font-weight: var(--weight-light);
    font-size: clamp(28px, 4.5vw, 48px);
    line-height: var(--leading-snug);
    color: var(--cream);
    margin: 0 auto 24px;
    max-width: 620px;
    letter-spacing: var(--tracking-tight);
  }

  .why-headline em {
    font-style: italic;
    color: var(--gold-light);
  }

  .why-text {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--cream);
    max-width: 620px;
    margin: 0 auto 36px;
  }

  .why-cta-row {
    display: flex;
    gap: 28px;
    flex-wrap: wrap;
    max-width: 620px;
    margin: 0 auto;
  }

  .why-cta,
  .why-cta-secondary {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: var(--weight-regular);
    font-size: var(--text-xl);
    text-decoration: none;
    padding: 4px 0 6px;
    transition: color 0.25s;
    position: relative;
    display: inline-block;
  }

  .why-cta {
    color: var(--gold-light);
    border-bottom: 2px solid var(--gold);
  }

  .why-cta-secondary {
    color: var(--cream);
    border-bottom: 2px solid rgba(200, 164, 90, 0.5);
  }

  .why-cta::after,
  .why-cta-secondary::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -2px;
    width: 0;
    height: 2px;
    background: var(--cream);
    transition: width 0.35s ease;
  }

  .why-cta:hover,
  .why-cta-secondary:hover {
    color: var(--cream);
  }

  .why-cta:hover::after,
  .why-cta-secondary:hover::after {
    width: 100%;
  }

  /* ─── ANIMATIONS ─── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(22px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.85s ease, transform 0.85s ease;
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 900px) {
    .hero,
    .why-block,
    .chapter,
    .chapter-break {
      padding-left: 24px;
      padding-right: 24px;
    }
    .hero { padding-top: 120px; padding-bottom: 56px; }
    .chapter { padding-top: 64px; padding-bottom: 48px; }
    .chapter-soon { padding-top: 48px; padding-bottom: 40px; }
    .chapter-head { gap: 18px; }
    .why-block { padding: 56px 24px 80px; }
  }

  @media (max-width: 480px) {
    .chapter-head { flex-direction: column; align-items: flex-start; gap: 8px; }
    .chapter-num { font-size: 56px; }
    .chapter-title { font-size: 32px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-label,
    .hero-name,
    .hero-sub,
    .hero-ghost {
      opacity: 1;
      animation: none;
    }
    .reveal { opacity: 1; transform: none; }
  }
</style>
</content>
</invoke>
---
import Layout from "../layouts/Layout.astro";
import BotanicalLayer from "../components/astro/BotanicalLayer.astro";
---

<Layout pageTitle="Dana Sandy | Product Manager & Entrepreneur">

  <!-- ─── HERO — full-bleed photo, editorial text ─── -->
  <section class="hero">
    <div class="hero-bg">
      <img src="/danainoffice.jpg" alt="Dana Sandy in office" />
    </div>
    <div class="hero-overlay"></div>

    <div class="hero-left">
      <h1 class="hero-title">Dana<em>Sandy</em></h1>
      <span class="hero-eyebrow">Product Manager &middot; Entrepreneur</span>
      <div class="hero-rule"></div>
      <p class="hero-tagline">Product Manager experienced in turning operational challenges into scalable, <strong>human-centered systems.</strong></p>
    </div>

    <div class="hero-pills">
      <span>Product Strategy</span>
      <span>Systems Thinking</span>
      <span>AI-Enabled Dev</span>
    </div>

    <div class="hero-crossword">
      <span>SANDY</span>
    </div>

    <div class="hero-scroll">
      <span class="scroll-text">Scroll</span>
      <span class="scroll-tick"></span>
    </div>
  </section>

  <!-- ─── MARQUEE STRIP ─── -->
  <div class="marquee-strip">
    <div class="marquee-track">
      <span>Product Strategy &nbsp;&diamond;&nbsp; Systems Thinking &nbsp;&diamond;&nbsp; AI-Enabled Development &nbsp;&diamond;&nbsp; SKAI Series &nbsp;&diamond;&nbsp; Product Strategy &nbsp;&diamond;&nbsp; Systems Thinking &nbsp;&diamond;&nbsp; AI-Enabled Development &nbsp;&diamond;&nbsp; SKAI Series &nbsp;&diamond;&nbsp; Product Strategy &nbsp;&diamond;&nbsp; Systems Thinking &nbsp;&diamond;&nbsp; AI-Enabled Development &nbsp;&diamond;&nbsp; SKAI Series &nbsp;&diamond;&nbsp;</span>
    </div>
  </div>

  <!-- ─── SERVICES / FEATURES ─── -->
  <section class="services reveal">
    <div class="services-header">
      <h2 class="services-title">What I<br /><em>Do</em></h2>
      <p class="services-desc">Three areas of deep expertise</p>
    </div>
    <div class="services-grid">
      <a href="/work/serve513" class="s-card">
        <span class="s-num" aria-hidden="true">01</span>
        <span class="s-title">Product Strategy</span>
        <p class="s-desc">Defining clear product direction by connecting user needs, operational realities, and business goals. I focus on translating complex problems into actionable roadmaps that deliver meaningful outcomes.</p>
        <span class="s-link">See it in practice <em>&rarr;</em> <span class="s-link-target">SERVE513 case study</span></span>
      </a>
      <a href="/work/the-playground/" class="s-card">
        <span class="s-num" aria-hidden="true">02</span>
        <span class="s-title">AI-Enabled Development</span>
        <p class="s-desc">Applying AI tools and emerging frameworks to accelerate discovery, prototyping, and solution development while maintaining strong product thinking and user focus.</p>
        <span class="s-link">Read the case study <em>&rarr;</em> <span class="s-link-target">The Playground</span></span>
      </a>
      <a href="/about" class="s-card">
        <span class="s-num" aria-hidden="true">03</span>
        <span class="s-title">Leadership</span>
        <p class="s-desc">Leading cross-functional teams with clarity and collaboration, aligning engineers, designers, and stakeholders to move ideas from concept to real-world solutions.</p>
        <span class="s-link">See the full journey <em>&rarr;</em> <span class="s-link-target">My story</span></span>
      </a>
    </div>
  </section>

  <!-- ─── SELECTED WORK ─── -->
  <section class="builds reveal" id="work">
    <BotanicalLayer variant="series" />

    <div class="work-inner">
      <div class="work-header">
        <div>
          <div class="work-eyebrow"><span class="rule"></span> Selected Work</div>
          <h2 class="work-title">Two projects.<br />One <em>becoming a platform</em>.<br />One shipped in <em>four days</em>.</h2>
        </div>
        <p class="work-sub">A long arc and a short loop, two ways to look at how I work.</p>
      </div>

      <!-- 01 · SERVE513 -->
      <div class="case serve513">
        <div class="case-meta">
          <div class="case-num">01</div>
          <div class="case-tags">
            <div class="case-tag">Role <span class="val">Founder &amp; Product Lead</span></div>
            <div class="case-tag">Active since <span class="val">2024 &middot; 24 events</span></div>
            <div class="case-tag">Partnership <span class="val">SALT Tampa Outreach</span></div>
          </div>
        </div>
        <div class="case-body">
          <span class="status-chip gold">Becoming a platform</span>
          <div class="case-kicker">
            <span class="dot"></span>
            <span>Case Study &middot; Community Tech &middot; HMIS Application</span>
          </div>
          <h3 class="case-name">SERVE<em>513</em></h3>
          <p class="case-tagline">Volunteers were burning out. Clients were waiting hours. The systems meant to help were slowing everything down, so I <em>rebuilt the workflow from the ground up</em>.</p>
          <div class="metrics">
            <div class="metric">
              <div class="metric-value">90<span class="unit">%</span></div>
              <div class="metric-label">Wait-time reduction</div>
              <p class="metric-note">Most had no wait; <em>under 5 min</em> at peak. Every minute saved matters.</p>
            </div>
            <div class="metric">
              <div class="metric-value">95<span class="unit">%</span></div>
              <div class="metric-label">Volunteer adoption</div>
              <p class="metric-note">No training overhead. Volunteers used it under real event pressure.</p>
            </div>
            <div class="metric">
              <div class="metric-value">23<span class="arrow">&rarr;</span><em>27</em></div>
              <div class="metric-label">Showers &middot; +17.4% capacity</div>
              <p class="metric-note">Hygiene access is a direct barrier to employment &amp; housing stability.</p>
            </div>
          </div>
          <div class="case-links">
            <a href="/work/serve513" class="case-link">Read the case study <span class="arrow">&rarr;</span></a>
          </div>
        </div>
      </div>

      <!-- 02 · The Playground -->
      <div class="case playground">
        <div class="case-meta">
          <div class="case-num">02</div>
          <div class="case-tags">
            <div class="case-tag">build <span class="val">ai_supported</span></div>
            <div class="case-tag">shipped <span class="val">2026</span></div>
            <div class="case-tag">stack <span class="val">react &middot; netlify &middot; clarity</span></div>
          </div>
        </div>
        <div class="case-body">
          <span class="status-chip green">Live &middot; case study</span>
          <div class="case-kicker">
            <span class="dot"></span>
            <span>Newly Shipped &middot; Design + Engineering + Product</span>
          </div>
          <h3 class="case-name">The <em>Playground</em></h3>
          <p class="case-tagline">A simple way to get honest, documented user feedback. No new sign-ups. No friction. <em>Four days, blank repo to live tool</em>, because I needed it.</p>
          <div class="metrics">
            <div class="metric">
              <div class="metric-label">AI-Supported Development</div>
              <p class="metric-note">AI accelerated design, engineering, and product: start to ship.</p>
            </div>
            <div class="metric">
              <div class="metric-label">Live in 4 days</div>
              <p class="metric-note">The short timeline shaped every decision in the build.</p>
            </div>
            <div class="metric">
              <div class="metric-label">Newly shipped</div>
              <p class="metric-note">Report section shows sample data. Real tests pending.</p>
            </div>
          </div>
          <div class="case-links">
            <a href="/work/the-playground/" class="case-link">Read the case study <span class="arrow">&rarr;</span></a>
            <a href="https://playground-uxtg.netlify.app" target="_blank" rel="noopener" class="case-link secondary">Visit the live site <span class="arrow">&#8599;</span></a>
            <a href="/posts/playground-part-1" class="case-link secondary">Read the build series <span class="arrow">&rarr;</span></a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── FEATURED SERIES ─── -->
  <section class="series-section reveal">
    <BotanicalLayer variant="series" />
    <span class="label">Featured Series</span>
    <h2>SKAI is the Limit?</h2>
    <p>Through a series of product experiments, I look at where AI fits and how it balances with human input to accelerate development.</p>
    <a href="/series/skai" class="nav-cta series-cta">Explore the series</a>
  </section>

</Layout>

<script>
  function initHomePage() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.05 });

    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

    setTimeout(() => {
      document.querySelectorAll('.reveal:not(.visible)').forEach(el => el.classList.add('visible'));
    }, 3000);
  }

  document.addEventListener('astro:page-load', initHomePage);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHomePage);
  } else {
    initHomePage();
  }
</script>

<style>
  /* ─── HERO ─── */
  .hero {
    position: relative;
    width: 100%;
    height: 100vh;
    min-height: 640px;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    margin-bottom: 0;
  }

  section.hero {
    margin: 0;
    padding: 0;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 20%;
    transform: scale(1.06);
    transition: transform 14s ease;
  }

  .hero:hover .hero-bg img {
    transform: scale(1);
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      to bottom,
      transparent 35%,
      rgba(44, 58, 34, 0.45) 65%,
      rgba(44, 58, 34, 0.82) 100%
    );
  }

  .hero-left {
    position: relative;
    z-index: 3;
    padding: 0 0 72px 64px;
    max-width: 680px;
  }

  .hero-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(90px, 14vw, 180px);
    line-height: 0.85;
    letter-spacing: 0.06em;
    color: var(--cream);
    text-shadow: 0 4px 48px rgba(0, 0, 0, 0.4);
    margin-bottom: 36px;
    opacity: 0;
    animation: slideRight 0.9s ease 0.42s forwards;
  }

  .hero-title em {
    display: block;
    font-style: italic;
    color: var(--gold-light);
    font-size: 0.92em;
  }

  .hero-eyebrow {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 11px;
    letter-spacing: 0.55em;
    text-transform: uppercase;
    color: var(--cream);
    margin-top: 20px;
    margin-bottom: 24px;
    text-shadow: 0 1px 12px rgba(0, 0, 0, 0.8);
    opacity: 0;
    animation: slideRight 0.9s ease 0.62s forwards;
  }

  .hero-rule {
    width: 44px;
    height: 1px;
    background: var(--gold);
    margin-bottom: 26px;
    opacity: 0;
    animation: fadeIn 1s ease 0.78s forwards;
  }

  .hero-tagline {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(16px, 1.8vw, 22px);
    line-height: 1.65;
    color: rgba(245, 240, 232, 0.82);
    max-width: 560px;
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.5);
    opacity: 0;
    animation: slideRight 0.9s ease 0.92s forwards;
    margin-bottom: 0;
  }

  .hero-tagline strong {
    font-style: normal;
    color: var(--cream);
    font-weight: 400;
  }

  /* ─── HERO PILLS ─── */
  .hero-pills {
    position: absolute;
    top: 50%;
    right: 52px;
    transform: translateY(-50%);
    z-index: 4;
    display: flex;
    flex-direction: column;
    gap: 14px;
    align-items: flex-end;
    opacity: 0;
    animation: fadeIn 1s ease 1.2s forwards;
  }

  .hero-pills span {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 11px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: rgba(245, 240, 232, 0.7);
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .hero-pills span::before {
    content: '';
    width: 24px;
    height: 1px;
    background: var(--gold);
    opacity: 0.6;
  }

  /* ─── GHOST "SANDY" ─── */
  .hero-crossword {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 2;
    display: flex;
    justify-content: flex-end;
    padding-right: 44px;
    pointer-events: none;
    overflow: hidden;
  }

  .hero-crossword span {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 600;
    font-size: clamp(110px, 18vw, 220px);
    line-height: 1;
    letter-spacing: -0.01em;
    color: transparent;
    -webkit-text-stroke: 1.5px rgba(200, 164, 90, 0.45);
    opacity: 0;
    animation: strokReveal 1.2s ease 1.1s forwards;
    white-space: nowrap;
  }

  /* ─── SCROLL CUE ─── */
  .hero-scroll {
    position: absolute;
    bottom: 32px;
    right: 52px;
    z-index: 4;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    opacity: 0;
    animation: fadeIn 1s ease 1.6s forwards;
  }

  .scroll-text {
    font-family: var(--font-body);
    font-weight: 200;
    font-size: 8px;
    letter-spacing: 0.34em;
    text-transform: uppercase;
    color: rgba(245, 240, 232, 0.5);
    writing-mode: vertical-rl;
  }

  .scroll-tick {
    width: 1px;
    height: 28px;
    background: var(--gold);
    transform-origin: top;
    animation: tickDown 2s ease infinite;
  }

  /* ─── MARQUEE STRIP ─── */
  .marquee-strip {
    position: relative;
    z-index: 10;
    background: var(--gold);
    padding: 28px 0;
    overflow: hidden;
    width: 100%;
    margin-top: -2px;
  }

  .marquee-track {
    display: flex;
    white-space: nowrap;
    animation: marqueeScroll 18s linear infinite;
  }

  .marquee-track span {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 13px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--olive-dark);
    flex-shrink: 0;
  }

  /* ─── SERVICES ─── */
  .services {
    background: var(--olive);
    padding: 100px 52px;
    position: relative;
  }

  .services::before {
    content: '';
    position: absolute;
    top: 0;
    left: 52px;
    right: 52px;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
    opacity: 0.3;
  }

  .services-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 72px;
  }

  .services-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(44px, 6vw, 84px);
    line-height: 0.9;
    letter-spacing: -0.02em;
    margin-bottom: 0;
  }

  .services-title em {
    font-style: italic;
    color: var(--gold);
  }

  .services-desc {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 18px;
    color: var(--text-muted);
    margin-bottom: 8px;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
  }

  .s-card {
    display: flex;
    flex-direction: column;
    padding: 40px 36px;
    border-right: 1px solid rgba(200, 164, 90, 0.12);
    position: relative;
    transition: background 0.4s;
    text-decoration: none;
    color: inherit;
  }

  .s-card:last-child {
    border-right: none;
  }

  .s-card::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--gold);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.5s ease;
  }

  .s-card:hover {
    background: rgba(200, 164, 90, 0.05);
  }

  .s-card:hover::after {
    transform: scaleX(1);
  }

  .s-num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: 64px;
    color: rgba(200, 164, 90, 0.14);
    line-height: 1;
    display: block;
    margin-bottom: 20px;
  }

  .s-title {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 16px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--gold);
    display: block;
    margin-bottom: 16px;
  }

  .s-desc {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 19px;
    line-height: 1.7;
    color: var(--text-muted);
    margin-bottom: 28px;
  }

  .s-link {
    margin-top: auto;
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 11px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--gold);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
    transition: color 0.3s, gap 0.3s;
  }

  .s-link em {
    font-style: normal;
    color: var(--gold);
    transition: transform 0.3s;
    display: inline-block;
  }

  .s-link-target {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: 14px;
    letter-spacing: 0;
    text-transform: none;
    color: var(--gold-light);
  }

  .s-card:hover .s-link {
    color: var(--gold-light);
    gap: 12px;
  }

  .s-card:hover .s-link em {
    transform: translateX(4px);
  }

  /* ─── SELECTED WORK ─── */
  .builds {
    background: var(--olive);
    position: relative;
    padding: 100px 0;
    overflow: hidden;
  }

  .builds > *:not(.botanical-layer) {
    position: relative;
    z-index: 1;
  }

  .work-inner {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 52px;
  }

  .work-header {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: end;
    gap: 40px;
    margin-bottom: 80px;
    padding-bottom: 32px;
    border-bottom: 1px solid var(--border);
  }

  .work-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    font-family: var(--font-body);
    font-size: 13px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 500;
    margin-bottom: 28px;
  }

  .work-eyebrow .rule {
    width: 32px;
    height: 1px;
    background: var(--gold);
    opacity: 0.5;
  }

  .work-title {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(40px, 5.5vw, 84px);
    line-height: 1.05;
    letter-spacing: -0.01em;
    margin: 0;
    color: var(--cream);
  }

  .work-title em {
    font-style: italic;
    color: var(--gold);
    font-weight: 400;
  }

  .work-sub {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: 22px;
    color: rgba(245, 240, 232, 0.78);
    line-height: 1.45;
    max-width: 380px;
    margin: 0;
  }

  .case {
    display: grid;
    grid-template-columns: 300px 1fr;
    gap: 80px;
    padding: 72px 0;
    border-top: 1px solid rgba(245, 240, 232, 0.08);
  }

  .case:first-of-type {
    border-top: none;
    padding-top: 0;
  }

  .case-meta {
    position: relative;
  }

  .case-num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: 104px;
    line-height: 0.85;
    color: var(--gold);
    letter-spacing: -0.04em;
    margin-bottom: 36px;
  }

  .case-tags {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .case-tag {
    font-family: var(--font-body);
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(245, 240, 232, 0.7);
    font-weight: 500;
    line-height: 1.4;
  }

  .case-tag .val {
    display: block;
    margin-top: 6px;
    color: var(--cream);
    font-weight: 400;
    text-transform: none;
    letter-spacing: 0;
    font-size: 15.5px;
  }

  .case-body {
    min-width: 0;
  }

  .status-chip {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    padding: 4px 12px;
    border-radius: 999px;
    margin-bottom: 20px;
    font-weight: 500;
  }

  .status-chip::before {
    content: "";
    width: 6px;
    height: 6px;
    border-radius: 999px;
    animation: live-pulse 2.4s ease-in-out infinite;
  }

  @keyframes live-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.45; }
  }

  .status-chip.gold {
    font-family: var(--font-body);
    color: var(--gold);
    border: 1px solid rgba(200, 164, 90, 0.4);
    background: rgba(200, 164, 90, 0.06);
  }

  .status-chip.gold::before {
    background: var(--gold);
    box-shadow: 0 0 6px var(--gold);
  }

  .status-chip.green {
    font-family: ui-monospace, SFMono-Regular, Menlo, "Liberation Mono", monospace;
    letter-spacing: 0.12em;
    color: #6fbf73;
    border: 1px solid rgba(111, 191, 115, 0.35);
    background: rgba(111, 191, 115, 0.06);
  }

  .status-chip.green::before {
    background: #6fbf73;
    box-shadow: 0 0 6px #6fbf73;
  }

  .case-kicker {
    font-family: var(--font-body);
    font-size: 12px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(245, 240, 232, 0.72);
    font-weight: 500;
    margin-bottom: 22px;
    display: flex;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
  }

  .case-kicker .dot {
    width: 4px;
    height: 4px;
    border-radius: 999px;
    background: var(--gold);
  }

  .case-name {
    font-family: var(--font-display);

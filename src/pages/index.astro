---
import Layout from "../layouts/Layout.astro";
import BotanicalLayer from "../components/astro/BotanicalLayer.astro";
---

<Layout pageTitle="Dana Sandy | Product Manager & Entrepreneur">
  <section class="hero">
    <BotanicalLayer variant="hero" />
    <div class="lights-layer">
      <div class="orb"></div><div class="orb"></div><div class="orb"></div>
      <div class="orb"></div><div class="orb"></div><div class="orb"></div>
      <div class="orb"></div><div class="orb"></div><div class="orb"></div>
      <div class="orb"></div><div class="orb"></div><div class="orb"></div>
      <div class="orb"></div><div class="orb"></div><div class="orb"></div>
    </div>
    <div class="hero-inner">
      <span class="label">Product Manager | Entrepreneur</span>
      <h1>Dana <em>Sandy</em></h1>
      <div class="hero-rule"></div>
      <p class="tagline">Building solutions that help people<br />focus on <em>what matters most.</em></p>
      <span class="label">Product Strategy &bull; Systems Thinking &bull; AI-Enabled Development</span>
    </div>
  </section>

  <section class="features">
    <div class="feature-card">
      <h3>Product Strategy</h3>
      <p>Defining clear product direction by connecting user needs, operational realities, and business goals. I focus on translating complex problems into actionable roadmaps that deliver meaningful outcomes.</p>
      <a href="/about">Learn more</a>
    </div>

    <div class="feature-card">
      <h3>AI-Enabled Product Development</h3>
      <p>Applying AI tools and emerging frameworks to accelerate discovery, prototyping, and solution development while maintaining strong product thinking and user focus.</p>
      <a href="/posts/1">Learn more</a>
    </div>

    <div class="feature-card">
      <h3>Leadership</h3>
      <p>Leading cross-functional teams with clarity and collaboration, aligning engineers, designers, and stakeholders to move ideas from concept to real-world solutions.</p>
      <a href="/about">Learn more</a>
    </div>
  </section>

  <section class="series-section">
    <BotanicalLayer variant="series" />
    <span class="label">Featured Series</span>
    <h2>SKAI is the Limit?</h2>
    <p>We gave AI a development team and one mission — to build a real app from scratch. Does SKAI have a limit?</p>
    <a href="/posts/1" class="btn">Explore the series</a>
  </section>
</Layout>

<style>
  .hero {
    text-align: center;
    padding: 8rem 2rem;
    padding-top: 10rem;
    position: relative;
    overflow: hidden;
  }

  .lights-layer {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    overflow: hidden;
  }

  .orb {
    position: absolute;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(201,169,110,0.55) 0%, rgba(201,169,110,0.1) 50%, transparent 70%);
    animation: orbDrift linear infinite;
    filter: blur(1px);
  }

  .orb:nth-child(1)  { width:6px; height:6px; left:8%;  top:72%; animation-duration:14s; animation-delay:0s;     opacity:0.7; }
  .orb:nth-child(2)  { width:4px; height:4px; left:18%; top:55%; animation-duration:18s; animation-delay:-3s;    opacity:0.5; }
  .orb:nth-child(3)  { width:8px; height:8px; left:28%; top:80%; animation-duration:12s; animation-delay:-6s;    opacity:0.6; }
  .orb:nth-child(4)  { width:3px; height:3px; left:38%; top:65%; animation-duration:20s; animation-delay:-1s;    opacity:0.4; }
  .orb:nth-child(5)  { width:5px; height:5px; left:50%; top:85%; animation-duration:16s; animation-delay:-8s;    opacity:0.65; }
  .orb:nth-child(6)  { width:7px; height:7px; left:62%; top:60%; animation-duration:11s; animation-delay:-4s;    opacity:0.5; }
  .orb:nth-child(7)  { width:4px; height:4px; left:72%; top:75%; animation-duration:19s; animation-delay:-9s;    opacity:0.45; }
  .orb:nth-child(8)  { width:6px; height:6px; left:82%; top:50%; animation-duration:13s; animation-delay:-2s;    opacity:0.6; }
  .orb:nth-child(9)  { width:3px; height:3px; left:90%; top:88%; animation-duration:17s; animation-delay:-7s;    opacity:0.4; }
  .orb:nth-child(10) { width:5px; height:5px; left:14%; top:30%; animation-duration:15s; animation-delay:-5s;    opacity:0.5; }
  .orb:nth-child(11) { width:9px; height:9px; left:45%; top:20%; animation-duration:22s; animation-delay:-11s;   opacity:0.35; }
  .orb:nth-child(12) { width:4px; height:4px; left:70%; top:35%; animation-duration:10s; animation-delay:-3.5s;  opacity:0.55; }
  .orb:nth-child(13) { width:6px; height:6px; left:55%; top:45%; animation-duration:14s; animation-delay:-6.5s;  opacity:0.45; }
  .orb:nth-child(14) { width:3px; height:3px; left:25%; top:15%; animation-duration:25s; animation-delay:-12s;   opacity:0.3; }
  .orb:nth-child(15) { width:5px; height:5px; left:88%; top:22%; animation-duration:16s; animation-delay:-0.5s;  opacity:0.5; }

  .hero-inner {
    max-width: 1000px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }

  .hero-inner > * {
    opacity: 0;
    animation: fadeUp 0.8s ease forwards;
  }

  .hero-inner > *:nth-child(1) { animation-delay: 0s; }
  .hero-inner > *:nth-child(2) { animation-delay: 0.2s; }
  .hero-inner > *:nth-child(3) { animation-delay: 0.5s; animation-name: expandLine; }
  .hero-inner > *:nth-child(4) { animation-delay: 0.7s; }
  .hero-inner > *:nth-child(5) { animation-delay: 1.0s; }

  .hero h1 {
    font-size: clamp(3rem, 7vw, 5.5rem);
    line-height: 0.95;
    letter-spacing: 0.06em;
    margin-bottom: 0;
    text-transform: uppercase;
  }

  .hero h1 em {
    font-style: italic;
    font-weight: 300;
    color: var(--gold);
  }

  .hero-rule {
    width: 0;
    height: 1px;
    background: var(--gold);
    margin: 2rem auto;
  }

  .tagline {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3.5vw, 2.25rem);
    font-weight: 300;
    color: var(--cream);
    line-height: 1.5;
    margin-bottom: 2.5rem;
    max-width: 750px;
    margin-left: auto;
    margin-right: auto;
  }

  .tagline em {
    font-style: italic;
    color: var(--gold);
  }

  .features {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 3rem;
    padding: 4rem 3rem;
    max-width: 1400px;
    margin: 0 auto;
    border-top: 1px solid var(--border);
  }

  .feature-card {
    text-align: center;
  }

  .feature-card h3 {
    margin-bottom: 1rem;
  }

  .feature-card p {
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }

  .feature-card a {
    color: var(--gold);
    text-decoration: underline;
    font-size: 0.95rem;
    letter-spacing: 0.05em;
  }

  .series-section {
    background-color: var(--olive-dark);
    padding: 5rem 0;
    text-align: center;
    border-top: 1px solid var(--border);
    position: relative;
    overflow: hidden;
    width: 100%;
  }

  .series-section > *:not(.botanical-layer) {
    position: relative;
    z-index: 1;
  }

  .series-section h2 {
    margin-bottom: 1rem;
  }

  .series-section p {
    color: var(--text-muted);
    max-width: 600px;
    margin: 0 auto 2rem;
    font-size: 1.125rem;
  }

  @media (max-width: 768px) {
    .hero {
      padding: 3rem 1.5rem 4rem;
    }

    .hero h1 {
      font-size: 2.5rem;
      line-height: 0.95;
    }

    .hero-rule {
      width: 40px;
      margin: 1.5rem auto;
    }

    .tagline {
      font-size: 1.05rem;
    }

    .label {
      font-size: 0.75rem;
      margin-bottom: 1.5rem;
    }

    .features {
      grid-template-columns: 1fr;
      padding: 3rem 1.5rem;
      gap: 2.5rem;
    }

    .feature-card h3 {
      font-size: 1.25rem;
    }

    .feature-card p {
      font-size: 0.95rem;
    }

    .series-section {
      padding: 4rem 1.5rem;
    }

    .series-section h2 {
      font-size: 2rem;
    }

    .series-section p {
      font-size: 1rem;
    }
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes orbDrift {
    0%   { transform: translateY(0px)    translateX(0px)   scale(1);    opacity: 0; }
    10%  { opacity: 1; }
    50%  { transform: translateY(-80px)  translateX(18px)  scale(1.15); }
    80%  { opacity: 0.6; }
    100% { transform: translateY(-160px) translateX(-12px) scale(0.8);  opacity: 0; }
  }

  @keyframes expandLine {
    from {
      opacity: 1;
      width: 0;
    }
    to {
      opacity: 1;
      width: 60px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-inner > * {
      opacity: 1;
      animation: none;
    }
    .hero-rule {
      width: 60px;
    }
    .orb {
      animation: none;
      opacity: 0.3;
    }
  }
</style>

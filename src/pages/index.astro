---
import Layout from "../layouts/Layout.astro";
import BotanicalLayer from "../components/astro/BotanicalLayer.astro";
---

<Layout pageTitle="Dana Sandy | Product Manager & Entrepreneur">
  <section class="hero">
    <BotanicalLayer variant="hero" />
    <div class="hero-inner">
      <span class="label">Product Manager | Entrepreneur</span>
      <h1>Dana<br /><em>Sandy</em></h1>
      <div class="hero-rule"></div>
      <p class="tagline">Building solutions that help people<br />focus on what matters most.</p>
      <span class="label">Product Strategy &bull; Systems Thinking &bull; AI-Enabled Development</span>
    </div>
  </section>

  <section class="features">
    <div class="feature-card">
      <h3>Product Strategy</h3>
      <p>Defining clear product direction by connecting user needs, operational realities, and business goals. I focus on translating complex problems into actionable roadmaps that deliver meaningful outcomes.</p>
      <a href="/about">Learn more</a>
    </div>

    <div class="feature-card">
      <h3>AI-Enabled Product Development</h3>
      <p>Applying AI tools and emerging frameworks to accelerate discovery, prototyping, and solution development while maintaining strong product thinking and user focus.</p>
      <a href="/posts/1">Learn more</a>
    </div>

    <div class="feature-card">
      <h3>Leadership</h3>
      <p>Leading cross-functional teams with clarity and collaboration, aligning engineers, designers, and stakeholders to move ideas from concept to real-world solutions.</p>
      <a href="/about">Learn more</a>
    </div>
  </section>

  <section class="series-section">
    <BotanicalLayer variant="series" />
    <span class="label">Featured Series</span>
    <h2>SKAI is the Limit?</h2>
    <p>We gave AI a development team and one mission — to build a real app from scratch. Does SKAI have a limit?</p>
    <a href="/posts/1" class="btn">Explore the series</a>
  </section>
</Layout>

<style>
  .hero {
    text-align: center;
    padding: 8rem 2rem;
    padding-top: 10rem;
    position: relative;
    overflow: hidden;
  }

  .hero-inner {
    max-width: 1000px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .hero h1 {
    font-size: clamp(3rem, 7vw, 5.5rem);
    line-height: 0.95;
    letter-spacing: 0.06em;
    margin-bottom: 0;
    text-transform: uppercase;
  }

  .hero h1 em {
    font-style: italic;
    font-weight: 300;
    color: var(--gold);
  }

  .hero-rule {
    width: 60px;
    height: 1px;
    background: var(--gold);
    margin: 2rem auto;
  }

  .tagline {
    font-family: var(--font-display);
    font-size: clamp(1.15rem, 2.5vw, 1.5rem);
    font-weight: 300;
    font-style: italic;
    color: var(--cream);
    line-height: 1.6;
    margin-bottom: 2.5rem;
    max-width: 650px;
    margin-left: auto;
    margin-right: auto;
  }

  .features {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 3rem;
    padding: 4rem 3rem;
    max-width: 1400px;
    margin: 0 auto;
    border-top: 1px solid var(--border);
  }

  .feature-card {
    text-align: center;
  }

  .feature-card h3 {
    margin-bottom: 1rem;
  }

  .feature-card p {
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }

  .feature-card a {
    color: var(--gold);
    text-decoration: underline;
    font-size: 0.95rem;
    letter-spacing: 0.05em;
  }

  .series-section {
    background-color: var(--olive-dark);
    padding: 5rem 0;
    text-align: center;
    border-top: 1px solid var(--border);
    position: relative;
    overflow: hidden;
    width: 100%;
  }

  .series-section > *:not(.botanical-layer) {
    position: relative;
    z-index: 1;
  }

  .series-section h2 {
    margin-bottom: 1rem;
  }

  .series-section p {
    color: var(--text-muted);
    max-width: 600px;
    margin: 0 auto 2rem;
    font-size: 1.125rem;
  }

  @media (max-width: 768px) {
    .hero {
      padding: 5rem 1.5rem 4rem;
    }

    .hero h1 {
      font-size: 2.5rem;
      line-height: 0.95;
    }

    .hero-rule {
      width: 40px;
      margin: 1.5rem auto;
    }

    .tagline {
      font-size: 1.05rem;
    }

    .label {
      font-size: 0.75rem;
      margin-bottom: 1.5rem;
    }

    .features {
      grid-template-columns: 1fr;
      padding: 3rem 1.5rem;
      gap: 2.5rem;
    }

    .feature-card h3 {
      font-size: 1.25rem;
    }

    .feature-card p {
      font-size: 0.95rem;
    }

    .series-section {
      padding: 4rem 1.5rem;
    }

    .series-section h2 {
      font-size: 2rem;
    }

    .series-section p {
      font-size: 1rem;
    }
  }
</style>

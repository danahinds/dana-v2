---
import Layout from "../layouts/Layout.astro";
import BotanicalLayer from "../components/astro/BotanicalLayer.astro";
---

<Layout pageTitle="Dana Sandy | Product Manager & Entrepreneur">

  <!-- ─── HERO — full-bleed photo, editorial text ─── -->
  <section class="hero">
    <div class="hero-bg">
      <img src="/danainoffice.jpg" alt="Dana Sandy in office" />
    </div>
    <div class="hero-overlay"></div>

    <div class="hero-left">
      <h1 class="hero-title">Dana<em>Sandy</em></h1>
      <span class="hero-eyebrow">Product Manager &middot; Entrepreneur</span>
      <div class="hero-rule"></div>
      <p class="hero-tagline">Building solutions that help people<br />focus on <strong>what matters most.</strong></p>
    </div>

    <div class="hero-pills">
      <span>Product Strategy</span>
      <span>Systems Thinking</span>
      <span>AI-Enabled Dev</span>
    </div>

    <div class="hero-crossword">
      <span>SANDY</span>
    </div>

    <div class="hero-scroll">
      <span class="scroll-text">Scroll</span>
      <span class="scroll-tick"></span>
    </div>
  </section>

  <!-- ─── MARQUEE STRIP ─── -->
  <div class="marquee-strip">
    <div class="marquee-track">
      <span>Product Strategy &nbsp;&diamond;&nbsp; Systems Thinking &nbsp;&diamond;&nbsp; AI-Enabled Development &nbsp;&diamond;&nbsp; SKAI Series &nbsp;&diamond;&nbsp; Product Strategy &nbsp;&diamond;&nbsp; Systems Thinking &nbsp;&diamond;&nbsp; AI-Enabled Development &nbsp;&diamond;&nbsp; SKAI Series &nbsp;&diamond;&nbsp; Product Strategy &nbsp;&diamond;&nbsp; Systems Thinking &nbsp;&diamond;&nbsp; AI-Enabled Development &nbsp;&diamond;&nbsp; SKAI Series &nbsp;&diamond;&nbsp;</span>
    </div>
  </div>

  <!-- ─── SERVICES / FEATURES ─── -->
  <section class="services reveal">
    <div class="services-header">
      <h2 class="services-title">What I<br /><em>Do</em></h2>
      <p class="services-desc">Three areas of deep expertise</p>
    </div>
    <div class="services-grid">
      <div class="s-card">
        <span class="s-num">01</span>
        <span class="s-title">Product Strategy</span>
        <p class="s-desc">Defining clear product direction by connecting user needs, operational realities, and business goals. I focus on translating complex problems into actionable roadmaps that deliver meaningful outcomes.</p>
      </div>
      <div class="s-card">
        <span class="s-num">02</span>
        <span class="s-title">AI-Enabled Development</span>
        <p class="s-desc">Applying AI tools and emerging frameworks to accelerate discovery, prototyping, and solution development while maintaining strong product thinking and user focus.</p>
      </div>
      <div class="s-card">
        <span class="s-num">03</span>
        <span class="s-title">Leadership</span>
        <p class="s-desc">Leading cross-functional teams with clarity and collaboration, aligning engineers, designers, and stakeholders to move ideas from concept to real-world solutions.</p>
      </div>
    </div>
  </section>

  <!-- ─── FEATURED SERIES ─── -->
  <section class="series-section reveal">
    <BotanicalLayer variant="series" />
    <span class="label">Featured Series</span>
    <h2>SKAI is the Limit?</h2>
    <p>We gave AI a development team and one mission — to build a real app from scratch. Does SKAI have a limit?</p>
    <a href="/posts/1" class="nav-cta series-cta">Explore the series</a>
  </section>

</Layout>

<script>
  function initHomePage() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.05 });

    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

    setTimeout(() => {
      document.querySelectorAll('.reveal:not(.visible)').forEach(el => el.classList.add('visible'));
    }, 3000);
  }

  document.addEventListener('astro:page-load', initHomePage);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHomePage);
  } else {
    initHomePage();
  }
</script>

<style>
  /* ─── HERO ─── */
  .hero {
    position: relative;
    width: 100%;
    height: 100vh;
    min-height: 640px;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    margin-bottom: 0;
  }

  section.hero {
    margin: 0;
    padding: 0;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 20%;
    transform: scale(1.06);
    transition: transform 14s ease;
  }

  .hero:hover .hero-bg img {
    transform: scale(1);
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      to bottom,
      transparent 35%,
      rgba(44, 58, 34, 0.45) 65%,
      rgba(44, 58, 34, 0.82) 100%
    );
  }

  .hero-left {
    position: relative;
    z-index: 3;
    padding: 0 0 72px 64px;
    max-width: 680px;
  }

  .hero-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(90px, 14vw, 180px);
    line-height: 0.85;
    letter-spacing: 0.06em;
    color: var(--cream);
    text-shadow: 0 4px 48px rgba(0, 0, 0, 0.4);
    margin-bottom: 36px;
    opacity: 0;
    animation: slideRight 0.9s ease 0.42s forwards;
  }

  .hero-title em {
    display: block;
    font-style: italic;
    color: var(--gold-light);
    font-size: 0.92em;
  }

  .hero-eyebrow {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 11px;
    letter-spacing: 0.55em;
    text-transform: uppercase;
    color: var(--cream);
    margin-top: 20px;
    margin-bottom: 24px;
    text-shadow: 0 1px 12px rgba(0, 0, 0, 0.8);
    opacity: 0;
    animation: slideRight 0.9s ease 0.62s forwards;
  }

  .hero-rule {
    width: 44px;
    height: 1px;
    background: var(--gold);
    margin-bottom: 26px;
    opacity: 0;
    animation: fadeIn 1s ease 0.78s forwards;
  }

  .hero-tagline {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(16px, 1.8vw, 22px);
    line-height: 1.65;
    color: rgba(245, 240, 232, 0.82);
    max-width: 400px;
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.5);
    opacity: 0;
    animation: slideRight 0.9s ease 0.92s forwards;
    margin-bottom: 0;
  }

  .hero-tagline strong {
    font-style: normal;
    color: var(--cream);
    font-weight: 400;
  }

  /* ─── HERO PILLS ─── */
  .hero-pills {
    position: absolute;
    top: 50%;
    right: 52px;
    transform: translateY(-50%);
    z-index: 4;
    display: flex;
    flex-direction: column;
    gap: 14px;
    align-items: flex-end;
    opacity: 0;
    animation: fadeIn 1s ease 1.2s forwards;
  }

  .hero-pills span {
    font-family: var(--font-body);
    font-weight: 200;
    font-size: 9px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: rgba(245, 240, 232, 0.7);
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .hero-pills span::before {
    content: '';
    width: 24px;
    height: 1px;
    background: var(--gold);
    opacity: 0.6;
  }

  /* ─── GHOST "SANDY" ─── */
  .hero-crossword {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 2;
    display: flex;
    justify-content: flex-end;
    padding-right: 44px;
    pointer-events: none;
    overflow: hidden;
  }

  .hero-crossword span {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 600;
    font-size: clamp(110px, 18vw, 220px);
    line-height: 1;
    letter-spacing: -0.01em;
    color: transparent;
    -webkit-text-stroke: 1.5px rgba(200, 164, 90, 0.45);
    opacity: 0;
    animation: strokReveal 1.2s ease 1.1s forwards;
    white-space: nowrap;
  }

  /* ─── SCROLL CUE ─── */
  .hero-scroll {
    position: absolute;
    bottom: 32px;
    right: 52px;
    z-index: 4;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    opacity: 0;
    animation: fadeIn 1s ease 1.6s forwards;
  }

  .scroll-text {
    font-family: var(--font-body);
    font-weight: 200;
    font-size: 8px;
    letter-spacing: 0.34em;
    text-transform: uppercase;
    color: rgba(245, 240, 232, 0.5);
    writing-mode: vertical-rl;
  }

  .scroll-tick {
    width: 1px;
    height: 28px;
    background: var(--gold);
    transform-origin: top;
    animation: tickDown 2s ease infinite;
  }

  /* ─── MARQUEE STRIP ─── */
  .marquee-strip {
    position: relative;
    z-index: 10;
    background: var(--gold);
    padding: 28px 0;
    overflow: hidden;
    width: 100%;
    margin-top: -2px;
  }

  .marquee-track {
    display: flex;
    white-space: nowrap;
    animation: marqueeScroll 18s linear infinite;
  }

  .marquee-track span {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 13px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--olive-dark);
    flex-shrink: 0;
  }

  /* ─── SERVICES ─── */
  .services {
    background: var(--olive);
    padding: 100px 52px;
    position: relative;
  }

  .services::before {
    content: '';
    position: absolute;
    top: 0;
    left: 52px;
    right: 52px;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
    opacity: 0.3;
  }

  .services-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 72px;
  }

  .services-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(44px, 6vw, 84px);
    line-height: 0.9;
    letter-spacing: -0.02em;
    margin-bottom: 0;
  }

  .services-title em {
    font-style: italic;
    color: var(--gold);
  }

  .services-desc {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 16px;
    color: var(--text-muted);
    margin-bottom: 8px;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
  }

  .s-card {
    padding: 40px 36px;
    border-right: 1px solid rgba(200, 164, 90, 0.12);
    position: relative;
    transition: background 0.4s;
  }

  .s-card:last-child {
    border-right: none;
  }

  .s-card::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--gold);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.5s ease;
  }

  .s-card:hover {
    background: rgba(200, 164, 90, 0.05);
  }

  .s-card:hover::after {
    transform: scaleX(1);
  }

  .s-num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: 64px;
    color: rgba(200, 164, 90, 0.14);
    line-height: 1;
    display: block;
    margin-bottom: 20px;
  }

  .s-title {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 11px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--gold);
    display: block;
    margin-bottom: 16px;
  }

  .s-desc {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: 17px;
    line-height: 1.7;
    color: var(--text-muted);
    margin-bottom: 0;
  }

  /* ─── SERIES SECTION ─── */
  .series-section {
    background-color: var(--olive-dark);
    padding: 100px 0;
    text-align: center;
    border-top: 1px solid var(--border);
    position: relative;
    overflow: hidden;
    width: 100%;
  }

  .series-section > *:not(.botanical-layer) {
    position: relative;
    z-index: 1;
  }

  .series-section h2 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(32px, 3.8vw, 52px);
    margin-bottom: 1rem;
  }

  .series-section p {
    color: var(--text-muted);
    max-width: 600px;
    margin: 0 auto 2.5rem;
    font-size: 1.125rem;
    font-family: var(--font-display);
    font-style: italic;
  }

  .series-cta {
    display: inline-block;
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 10px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--olive-dark);
    background: var(--cream);
    text-decoration: none;
    padding: 14px 32px;
    transition: background 0.3s, letter-spacing 0.3s;
  }

  .series-cta:hover {
    background: white;
    color: var(--olive-dark);
    letter-spacing: 0.36em;
  }

  /* ─── SCROLL REVEAL ─── */
  .reveal {
    opacity: 0;
    transform: translateY(32px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }

  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ─── ANIMATIONS ─── */
  @keyframes slideRight {
    from { opacity: 0; transform: translateX(-28px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  @keyframes strokReveal {
    from { opacity: 0; letter-spacing: 0.08em; }
    to   { opacity: 1; letter-spacing: -0.01em; }
  }

  @keyframes tickDown {
    0%   { transform: scaleY(0); opacity: 0; }
    30%  { transform: scaleY(1); opacity: 1; }
    70%  { transform: scaleY(1); opacity: 1; }
    100% { transform: scaleY(0); opacity: 0; transform-origin: bottom; }
  }

  @keyframes marqueeScroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 900px) {
    .hero {
      min-height: 500px;
    }

    .hero-left {
      padding: 0 0 48px 28px;
    }

    .hero-title {
      font-size: clamp(56px, 14vw, 90px);
    }

    .hero-pills {
      display: none;
    }

    .hero-crossword span {
      font-size: clamp(60px, 16vw, 110px);
    }

    .hero-scroll {
      display: none;
    }

    .services {
      padding: 60px 24px;
    }

    .services::before {
      left: 24px;
      right: 24px;
    }

    .services-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 8px;
      margin-bottom: 48px;
    }

    .services-grid {
      grid-template-columns: 1fr;
    }

    .s-card {
      border-right: none;
      border-bottom: 1px solid rgba(200, 164, 90, 0.12);
      padding: 32px 0;
    }

    .s-card:last-child {
      border-bottom: none;
    }

    .s-num {
      font-size: 48px;
    }

    .series-section {
      padding: 60px 24px;
    }

    .series-section h2 {
      font-size: 2rem;
    }

    .series-section p {
      font-size: 1rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-title,
    .hero-eyebrow,
    .hero-rule,
    .hero-tagline,
    .hero-pills,
    .hero-crossword span,
    .hero-scroll {
      opacity: 1;
      animation: none;
    }

    .hero-bg img {
      transform: scale(1);
      transition: none;
    }

    .scroll-tick {
      animation: none;
    }

    .marquee-track {
      animation: none;
    }

    .reveal {
      opacity: 1;
      transform: none;
    }
  }
</style>
</Layout>

---
import Layout from "../layouts/Layout.astro";
---

<Layout pageTitle="About — Dana Sandy">

  <!-- ORB LAYER -->
  <div class="orb-layer">
    <div class="orb orb-a"></div>
    <div class="orb orb-b"></div>
    <div class="orb orb-c"></div>
    <div class="orb orb-d"></div>
    <div class="orb orb-e"></div>
  </div>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-ghost">About</div>
    <div class="hero-content">
      <div class="hero-text">
        <p class="hero-label">The Story Behind the Work</p>
        <h1 class="hero-name">Hello,<br>I'm <em>Dana.</em></h1>
        <p class="hero-sub">A Product Manager who builds practical solutions that help organizations serve people better.</p>
        <a href="/contact" class="hero-cta">Let's Build Something Together</a>
      </div>
      <div class="hero-illustration">
        <img src="/dana-illustration.png" alt="Dana Sandy illustration" />
      </div>
    </div>
  </section>

  <!-- GOLD DIVIDER -->
  <svg class="gold-divider" viewBox="0 0 1440 48" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M0 24 Q180 4 360 24 T720 24 T1080 24 T1440 24" fill="none" stroke="rgba(200,164,90,0.35)" stroke-width="1"/>
    <path d="M0 32 Q240 48 480 28 T960 32 T1440 28" fill="none" stroke="rgba(226,192,122,0.15)" stroke-width="0.75"/>
    <circle cx="360" cy="24" r="3" fill="rgba(200,164,90,0.5)"/>
    <circle cx="720" cy="24" r="2" fill="rgba(200,164,90,0.4)"/>
    <circle cx="1080" cy="24" r="3" fill="rgba(200,164,90,0.5)"/>
  </svg>

  <!-- BIO -->
  <section class="bio reveal">
    <div class="bio-sidebar">
      <div>
        <p class="stat-label">Based In</p>
        <p class="stat-value">United States<br><em>Originally from T&T</em></p>
      </div>
      <div>
        <p class="stat-label">Current Focus</p>
        <p class="stat-value"><em>Serve513</em><br>Outreach platform for unsheltered communities</p>
      </div>
      <div>
        <p class="stat-label">Background</p>
        <p class="stat-value">Tech Founder<br>Healthcare Ops<br>Product Management</p>
      </div>
      <a href="/contact" class="bio-cta">Let's Create Something Great</a>
    </div>

    <div class="bio-body">
      <p>
        I started my career in <strong>Trinidad &amp; Tobago</strong>, where I co-founded a computer
        leasing company focused on bringing technology into communities with limited access. That early
        experience <span class="hl">shaped how I think about systems, people, and the role technology can play in creating opportunity.</span>
      </p>
      <p>
        In 2008, I presented <strong>Tech Pods for Schools</strong> to the <strong>United Nations</strong>,
        a concept for connected learning labs designed for underserved schools across the Caribbean.
        It was my first real experience thinking about product design at scale — <span class="hl">identifying meaningful problems, designing within constraints, and building solutions around real human needs.</span>
      </p>
      <p>
        After relocating to the United States, I spent over a decade working across <strong>healthcare operations</strong>,
        hospitals, and pharmacy systems, where I learned to navigate operational complexity, improve
        workflows, and support systems serving thousands of people.
      </p>
      <p>
        A major turning point came after being laid off during a season when my family needed me most.
        While supporting my child through an important educational transition, I made a commitment not
        to disconnect from the work I loved. That decision led me into community outreach and volunteer
        work throughout the <strong>Tampa Bay area</strong>, where I began noticing <span class="hl">recurring operational and coordination challenges across nonprofit organizations.</span>
      </p>
      <p>
        Those experiences eventually led to the creation of <strong>Serve513</strong>, a platform
        designed to improve coordination and operational workflows for community organizations, and
        later <strong>Say Hello Neighbor Inc.</strong>, an officially registered nonprofit organization
        focused on <span class="hl">building scalable, human-centered systems for underserved communities.</span>
      </p>
      <p>
        Today, I continue exploring the intersection of operational systems, product thinking, and
        emerging technologies, including <span class="hl">AI-assisted workflows and product development.</span>
      </p>
      <p>
        Across every environment, my ability to <span class="hl">identify operational challenges and design human-centered solutions</span>
        has shaped the way I approach Product Management today.
      </p>
    </div>
  </section>

  <!-- CREDENTIALS -->
  <section class="credentials reveal">
    <p class="cred-label">Education &amp; Certifications</p>
    <div class="cred-grid">
      <div class="cred-card">
        <div class="cred-abbr">BS</div>
        <p class="cred-name">Degree</p>
        <p class="cred-desc">Bachelor of Science in Management Information Systems with a concentration in Cybersecurity</p>
      </div>
      <div class="cred-card">
        <div class="cred-abbr">CSPO</div>
        <p class="cred-name">Certification</p>
        <p class="cred-desc">Certified Scrum Product Owner — agile product leadership and backlog management</p>
      </div>
      <div class="cred-card">
        <div class="cred-abbr">CSM</div>
        <p class="cred-name">Certification</p>
        <p class="cred-desc">Certified ScrumMaster — facilitating high-performing agile teams and sprint ceremonies</p>
      </div>
    </div>
  </section>

</Layout>

<script>
  function initAboutPage() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.05 });

    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

    setTimeout(() => {
      document.querySelectorAll('.reveal:not(.visible)').forEach(el => el.classList.add('visible'));
    }, 3000);
  }

  document.addEventListener('astro:page-load', initAboutPage);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAboutPage);
  } else {
    initAboutPage();
  }
</script>

<style>
  /* ─── ORB LAYER ─── */
  .orb-layer {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .orb {
    position: absolute;
    border-radius: 50%;
  }

  .orb-a {
    width: 300px; height: 300px; top: 10vh; left: 5vw;
    background: radial-gradient(circle, rgba(200,164,90,0.14) 0%, transparent 70%);
    animation: floatOrb 9s ease-in-out infinite;
  }

  .orb-b {
    width: 200px; height: 200px; top: 35vh; right: 6vw;
    background: radial-gradient(circle, rgba(226,192,122,0.18) 0%, transparent 70%);
    animation: floatOrb 12s ease-in-out 1.5s infinite;
  }

  .orb-c {
    width: 140px; height: 140px; top: 60vh; left: 20vw;
    background: radial-gradient(circle, rgba(200,164,90,0.20) 0%, transparent 70%);
    animation: floatOrb 7s ease-in-out 3s infinite;
  }

  .orb-d {
    width: 90px; height: 90px; top: 75vh; right: 25vw;
    background: radial-gradient(circle, rgba(226,192,122,0.22) 0%, transparent 70%);
    animation: floatOrb 10s ease-in-out 0.8s infinite;
  }

  .orb-e {
    width: 240px; height: 240px; bottom: 10vh; right: 4vw;
    background: radial-gradient(circle, rgba(200,164,90,0.12) 0%, transparent 70%);
    animation: floatOrb 14s ease-in-out 2s infinite;
  }

  @keyframes floatOrb {
    0%, 100% { transform: translateY(0) scale(1); }
    50% { transform: translateY(-30px) scale(1.06); }
  }

  /* ─── HERO ─── */
  .hero {
    padding: 160px 72px 80px;
    position: relative;
    z-index: 1;
  }

  .hero-content {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 40px;
  }

  .hero-text {
    flex: 1;
  }

  .hero-illustration {
    flex-shrink: 0;
    width: 620px;
    margin-right: -40px;
    margin-bottom: 40px;
    filter: drop-shadow(0 0 40px rgba(200,164,90,0.3));
    animation: illuFloat 6s ease-in-out infinite;
  }

  .hero-illustration img {
    width: 100%;
    display: block;
  }

  @keyframes illuFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-18px); }
  }

  .hero-label {
    font-family: var(--font-body);
    font-weight: 200;
    font-size: 9px;
    letter-spacing: 0.55em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 24px;
    opacity: 0;
    animation: fadeUp 0.9s ease 0.1s forwards;
  }

  .hero-name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(72px, 12vw, 150px);
    line-height: 0.88;
    letter-spacing: -0.02em;
    color: var(--cream);
    opacity: 0;
    animation: fadeUp 0.9s ease 0.25s forwards;
  }

  .hero-name em {
    font-style: italic;
    color: var(--gold-light);
    display: block;
  }

  .hero-sub {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(17px, 2vw, 26px);
    line-height: 1.6;
    color: var(--text-muted);
    margin-top: 36px;
    max-width: 560px;
    opacity: 0;
    animation: fadeUp 0.9s ease 0.5s forwards;
  }

  .hero-cta {
    display: inline-block;
    margin-top: 36px;
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 12px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--olive-dark);
    background: var(--cream);
    text-decoration: none;
    padding: 14px 36px;
    transition: background 0.3s, letter-spacing 0.3s;
    opacity: 0;
    animation: fadeUp 0.9s ease 0.7s forwards;
  }

  .hero-cta:hover {
    background: white;
    letter-spacing: 0.32em;
  }

  .hero-ghost {
    position: absolute;
    right: 40px;
    top: 110px;
    font-family: var(--font-display);
    font-weight: 600;
    font-style: italic;
    font-size: clamp(100px, 18vw, 200px);
    color: transparent;
    -webkit-text-stroke: 1px rgba(200,164,90,0.10);
    pointer-events: none;
    user-select: none;
    opacity: 0;
    animation: fadeIn 1.4s ease 0.9s forwards;
  }

  /* ─── GOLD DIVIDER ─── */
  .gold-divider {
    width: 100%;
    overflow: visible;
    display: block;
    margin: 0;
    height: 48px;
    position: relative;
    z-index: 1;
  }

  /* ─── PULL QUOTE ─── */
  .pull-quote {
    padding: 60px 72px;
    max-width: 1000px;
    position: relative;
    z-index: 1;
  }

  .pull-quote blockquote {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(22px, 3vw, 38px);
    line-height: 1.5;
    color: var(--cream);
  }

  .pull-quote blockquote strong {
    font-style: normal;
    color: var(--gold-light);
    font-weight: 600;
  }

  /* ─── BIO ─── */
  .bio {
    padding: 80px 72px;
    display: grid;
    grid-template-columns: 420px 1fr;
    gap: 80px;
    max-width: 1400px;
    position: relative;
    z-index: 1;
  }

  .bio-sidebar {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .stat-label {
    font-family: var(--font-body);
    font-weight: 200;
    font-size: 9px;
    letter-spacing: 0.45em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 8px;
  }

  .stat-value {
    font-family: var(--font-display);
    font-size: 17px;
    color: var(--cream);
    line-height: 1.55;
  }

  .stat-value em {
    font-style: italic;
    color: var(--gold-light);
  }

  .bio-cta {
    display: inline-block;
    margin-top: 12px;
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 11px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--olive-dark);
    background: var(--gold);
    text-decoration: none;
    padding: 14px 32px;
    transition: background 0.3s, letter-spacing 0.3s;
  }

  .bio-cta:hover {
    background: var(--gold-light);
    letter-spacing: 0.32em;
  }

  .bio-body p {
    font-family: var(--font-display);
    font-size: 19px;
    line-height: 1.95;
    color: var(--text-muted);
    margin-bottom: 28px;
  }

  .bio-body p:last-child {
    margin-bottom: 0;
  }

  .bio-body strong {
    color: var(--cream);
    font-weight: 600;
  }

  .bio-body .hl {
    font-style: italic;
    color: var(--gold-light);
  }

  /* ─── CREDENTIALS ─── */
  .credentials {
    padding: 0 72px 80px;
    position: relative;
    z-index: 1;
  }

  .cred-label {
    font-family: var(--font-body);
    font-weight: 200;
    font-size: 9px;
    letter-spacing: 0.5em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 36px;
  }

  .cred-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .cred-card {
    border: 1px solid rgba(200,164,90,0.18);
    padding: 36px 28px;
    position: relative;
    overflow: hidden;
    transition: background 0.4s, border-color 0.4s;
  }

  .cred-card::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
    transform: scaleX(0);
    transition: transform 0.5s;
    transform-origin: left;
  }

  .cred-card:hover {
    background: rgba(200,164,90,0.04);
    border-color: rgba(200,164,90,0.35);
  }

  .cred-card:hover::after {
    transform: scaleX(1);
  }

  .cred-abbr {
    font-family: var(--font-display);
    font-size: 38px;
    font-weight: 600;
    font-style: italic;
    color: rgba(200,164,90,0.2);
    margin-bottom: 16px;
    line-height: 1;
  }

  .cred-name {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 10px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 10px;
  }

  .cred-desc {
    font-family: var(--font-display);
    font-size: 16px;
    line-height: 1.7;
    color: var(--text-muted);
  }

  /* ─── ANIMATIONS ─── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(22px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.85s ease, transform 0.85s ease;
  }

  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 900px) {
    .hero,
    .pull-quote,
    .bio,
    .credentials {
      padding-left: 24px;
      padding-right: 24px;
    }

    .hero-content {
      flex-direction: column;
    }

    .hero-illustration {
      width: 320px;
      margin-right: 0;
      margin-bottom: 0;
      align-self: center;
    }

    .bio {
      grid-template-columns: 1fr;
      gap: 48px;
    }

    .cred-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-label,
    .hero-name,
    .hero-sub,
    .hero-ghost {
      opacity: 1;
      animation: none;
    }

    .orb,
    .hero-illustration {
      animation: none;
    }

    .reveal {
      opacity: 1;
      transform: none;
    }
  }
</style>

---
import Layout from "../layouts/Layout.astro";
---

<Layout pageTitle="About — Dana Sandy">

  <!-- ORB LAYER -->
  <div class="orb-layer">
    <div class="orb orb-a"></div>
    <div class="orb orb-b"></div>
    <div class="orb orb-c"></div>
    <div class="orb orb-d"></div>
    <div class="orb orb-e"></div>
  </div>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-ghost">About</div>
    <div class="hero-content">
      <div class="hero-text">
        <p class="hero-label">The Story Behind the Work</p>
        <h1 class="hero-name">Hello,<br>I'm <em>Dana.</em></h1>
        <p class="hero-sub">A Product Manager who builds practical solutions that help organizations serve people better.</p>
      </div>
      <div class="hero-illustration">
        <img src="/dana-illustration.png" alt="Dana Sandy illustration" />
      </div>
    </div>
  </section>

  <!-- GOLD DIVIDER 1 -->
  <svg class="gold-divider" viewBox="0 0 1440 48" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M0 24 Q180 4 360 24 T720 24 T1080 24 T1440 24" fill="none" stroke="rgba(200,164,90,0.35)" stroke-width="1"/>
    <path d="M0 32 Q240 48 480 28 T960 32 T1440 28" fill="none" stroke="rgba(226,192,122,0.15)" stroke-width="0.75"/>
    <circle cx="360" cy="24" r="3" fill="rgba(200,164,90,0.5)"/>
    <circle cx="720" cy="24" r="2" fill="rgba(200,164,90,0.4)"/>
    <circle cx="1080" cy="24" r="3" fill="rgba(200,164,90,0.5)"/>
  </svg>

  <!-- PULL QUOTE -->
  <div class="pull-quote reveal">
    <blockquote>
      My work has always centered on one thing —
      <strong>expanding access</strong> and solving the problems that matter most to real people.
    </blockquote>
  </div>

  <!-- GOLD DIVIDER 2 -->
  <svg class="gold-divider" viewBox="0 0 1440 48" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
    <line x1="72" y1="24" x2="400" y2="24" stroke="rgba(200,164,90,0.4)" stroke-width="0.75"/>
    <circle cx="400" cy="24" r="2.5" fill="none" stroke="rgba(200,164,90,0.5)" stroke-width="1"/>
    <line x1="406" y1="24" x2="700" y2="24" stroke="rgba(200,164,90,0.2)" stroke-width="0.5" stroke-dasharray="4 6"/>
    <circle cx="700" cy="24" r="1.5" fill="rgba(200,164,90,0.4)"/>
    <line x1="706" y1="24" x2="1040" y2="24" stroke="rgba(200,164,90,0.2)" stroke-width="0.5" stroke-dasharray="4 6"/>
    <circle cx="1040" cy="24" r="2.5" fill="none" stroke="rgba(200,164,90,0.5)" stroke-width="1"/>
    <line x1="1046" y1="24" x2="1370" y2="24" stroke="rgba(200,164,90,0.4)" stroke-width="0.75"/>
  </svg>

  <!-- TIMELINE -->
  <section class="timeline-section reveal">
    <p class="timeline-eyebrow">The Journey</p>
    <div class="timeline-track">
      <div class="timeline-line"></div>

      <div class="timeline-item">
        <div class="timeline-dot"></div>
        <div class="timeline-year">2005</div>
        <div class="timeline-title">Tech Founder</div>
        <div class="timeline-desc">Co-founded a computer leasing company in Trinidad &amp; Tobago, putting technology in the hands of communities that needed it most.</div>
      </div>

      <div class="timeline-item">
        <div class="timeline-dot"></div>
        <div class="timeline-year">2008</div>
        <div class="timeline-title">United Nations</div>
        <div class="timeline-desc">Presented Tech Pods for Schools — a proposal to bring connected learning labs to underserved schools — directly to the UN.</div>
      </div>

      <div class="timeline-item">
        <div class="timeline-dot"></div>
        <div class="timeline-year">2012</div>
        <div class="timeline-title">Healthcare Operations</div>
        <div class="timeline-desc">Moved to the US and spent over a decade leading operations in hospitals and pharmacy systems, improving care at scale.</div>
      </div>

      <div class="timeline-item">
        <div class="timeline-dot"></div>
        <div class="timeline-year">2021</div>
        <div class="timeline-title">Product Management</div>
        <div class="timeline-desc">Earned her CSPO and CSM, formalizing years of product thinking and stepping fully into the PM world.</div>
      </div>

      <div class="timeline-item">
        <div class="timeline-dot"></div>
        <div class="timeline-year">Now</div>
        <div class="timeline-title">Building Serve513</div>
        <div class="timeline-desc">Founder of Serve513 — a platform connecting outreach organizations with the resources and coordination they need to serve unsheltered communities.</div>
      </div>
    </div>
  </section>

  <!-- GOLD DIVIDER 3 -->
  <svg class="gold-divider" viewBox="0 0 1440 48" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
    <line x1="72" y1="24" x2="400" y2="24" stroke="rgba(200,164,90,0.4)" stroke-width="0.75"/>
    <circle cx="400" cy="24" r="2.5" fill="none" stroke="rgba(200,164,90,0.5)" stroke-width="1"/>
    <line x1="406" y1="24" x2="700" y2="24" stroke="rgba(200,164,90,0.2)" stroke-width="0.5" stroke-dasharray="4 6"/>
    <circle cx="700" cy="24" r="1.5" fill="rgba(200,164,90,0.4)"/>
    <line x1="706" y1="24" x2="1040" y2="24" stroke="rgba(200,164,90,0.2)" stroke-width="0.5" stroke-dasharray="4 6"/>
    <circle cx="1040" cy="24" r="2.5" fill="none" stroke="rgba(200,164,90,0.5)" stroke-width="1"/>
    <line x1="1046" y1="24" x2="1370" y2="24" stroke="rgba(200,164,90,0.4)" stroke-width="0.75"/>
  </svg>

  <!-- BIO -->
  <section class="bio reveal">
    <div class="bio-sidebar">
      <div>
        <p class="stat-label">Based In</p>
        <p class="stat-value">United States<br><em>Originally from T&T</em></p>
      </div>
      <div>
        <p class="stat-label">Current Focus</p>
        <p class="stat-value"><em>Serve513</em><br>Outreach platform for unsheltered communities</p>
      </div>
      <div>
        <p class="stat-label">Background</p>
        <p class="stat-value">Tech Founder<br>Healthcare Ops<br>Product Management</p>
      </div>
    </div>

    <div class="bio-body">
      <p>
        I started my career in <strong>Trinidad &amp; Tobago</strong>, co-founding a computer leasing company
        that put technology directly into communities that needed it most. That experience — watching
        people light up when given access to tools they'd never had — <span class="hl">shaped everything that followed.</span>
      </p>
      <p>
        In 2008, I had the opportunity to present <strong>Tech Pods for Schools</strong> to the
        <strong>United Nations</strong> — a concept for bringing connected learning labs to underserved
        schools across the Caribbean. It was my first real taste of product thinking at scale:
        <span class="hl">identifying a need, designing a solution, and pitching it to the people who could make it happen.</span>
      </p>
      <p>
        After relocating to the US, I spent over a decade in <strong>healthcare operations</strong>,
        managing complex workflows across hospitals and pharmacy systems. I learned to lead
        cross-functional teams, optimize processes, and build systems that served thousands of patients.
      </p>
      <p>
        Today I'm channeling all of that into <strong>Serve513</strong> — a platform designed to help
        outreach organizations coordinate resources for unsheltered communities. I'm also exploring
        the intersection of <span class="hl">AI and product development</span> through my series,
        <em>SKAI is the Limit?</em>, where a team of AI agents attempts to build a real application from scratch.
      </p>
    </div>
  </section>

  <!-- CREDENTIALS -->
  <section class="credentials reveal">
    <p class="cred-label">Education &amp; Certifications</p>
    <div class="cred-grid">
      <div class="cred-card">
        <div class="cred-abbr">BS</div>
        <p class="cred-name">Degree</p>
        <p class="cred-desc">Bachelor of Science in Management Information Systems with a concentration in Cybersecurity</p>
      </div>
      <div class="cred-card">
        <div class="cred-abbr">CSPO</div>
        <p class="cred-name">Certification</p>
        <p class="cred-desc">Certified Scrum Product Owner — agile product leadership and backlog management</p>
      </div>
      <div class="cred-card">
        <div class="cred-abbr">CSM</div>
        <p class="cred-name">Certification</p>
        <p class="cred-desc">Certified ScrumMaster — facilitating high-performing agile teams and sprint ceremonies</p>
      </div>
    </div>
  </section>

</Layout>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.15 });

  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
</script>

<style>
  /* ─── ORB LAYER ─── */
  .orb-layer {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .orb {
    position: absolute;
    border-radius: 50%;
  }

  .orb-a {
    width: 300px; height: 300px; top: 10vh; left: 5vw;
    background: radial-gradient(circle, rgba(200,164,90,0.14) 0%, transparent 70%);
    animation: floatOrb 9s ease-in-out infinite;
  }

  .orb-b {
    width: 200px; height: 200px; top: 35vh; right: 6vw;
    background: radial-gradient(circle, rgba(226,192,122,0.18) 0%, transparent 70%);
    animation: floatOrb 12s ease-in-out 1.5s infinite;
  }

  .orb-c {
    width: 140px; height: 140px; top: 60vh; left: 20vw;
    background: radial-gradient(circle, rgba(200,164,90,0.20) 0%, transparent 70%);
    animation: floatOrb 7s ease-in-out 3s infinite;
  }

  .orb-d {
    width: 90px; height: 90px; top: 75vh; right: 25vw;
    background: radial-gradient(circle, rgba(226,192,122,0.22) 0%, transparent 70%);
    animation: floatOrb 10s ease-in-out 0.8s infinite;
  }

  .orb-e {
    width: 240px; height: 240px; bottom: 10vh; right: 4vw;
    background: radial-gradient(circle, rgba(200,164,90,0.12) 0%, transparent 70%);
    animation: floatOrb 14s ease-in-out 2s infinite;
  }

  @keyframes floatOrb {
    0%, 100% { transform: translateY(0) scale(1); }
    50% { transform: translateY(-30px) scale(1.06); }
  }

  /* ─── HERO ─── */
  .hero {
    padding: 160px 72px 80px;
    position: relative;
    z-index: 1;
  }

  .hero-content {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 40px;
  }

  .hero-text {
    flex: 1;
  }

  .hero-illustration {
    flex-shrink: 0;
    width: 560px;
    margin-right: -40px;
    margin-bottom: -40px;
    filter: drop-shadow(0 0 40px rgba(200,164,90,0.3));
    animation: illuFloat 6s ease-in-out infinite;
  }

  .hero-illustration img {
    width: 100%;
    display: block;
  }

  @keyframes illuFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-18px); }
  }

  .hero-label {
    font-family: var(--font-body);
    font-weight: 200;
    font-size: 9px;
    letter-spacing: 0.55em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 24px;
    opacity: 0;
    animation: fadeUp 0.9s ease 0.1s forwards;
  }

  .hero-name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(72px, 12vw, 150px);
    line-height: 0.88;
    letter-spacing: -0.02em;
    color: var(--cream);
    opacity: 0;
    animation: fadeUp 0.9s ease 0.25s forwards;
  }

  .hero-name em {
    font-style: italic;
    color: var(--gold-light);
    display: block;
  }

  .hero-sub {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(17px, 2vw, 26px);
    line-height: 1.6;
    color: var(--text-muted);
    margin-top: 36px;
    max-width: 560px;
    opacity: 0;
    animation: fadeUp 0.9s ease 0.5s forwards;
  }

  .hero-ghost {
    position: absolute;
    right: 40px;
    top: 110px;
    font-family: var(--font-display);
    font-weight: 600;
    font-style: italic;
    font-size: clamp(100px, 18vw, 200px);
    color: transparent;
    -webkit-text-stroke: 1px rgba(200,164,90,0.10);
    pointer-events: none;
    user-select: none;
    opacity: 0;
    animation: fadeIn 1.4s ease 0.9s forwards;
  }

  /* ─── GOLD DIVIDER ─── */
  .gold-divider {
    width: 100%;
    overflow: visible;
    display: block;
    margin: 0;
    height: 48px;
    position: relative;
    z-index: 1;
  }

  /* ─── PULL QUOTE ─── */
  .pull-quote {
    padding: 60px 72px;
    max-width: 1000px;
    position: relative;
    z-index: 1;
  }

  .pull-quote blockquote {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(22px, 3vw, 38px);
    line-height: 1.5;
    color: var(--cream);
  }

  .pull-quote blockquote strong {
    font-style: normal;
    color: var(--gold-light);
    font-weight: 600;
  }

  /* ─── TIMELINE ─── */
  .timeline-section {
    padding: 80px 80px 60px;
    overflow: hidden;
    position: relative;
    z-index: 1;
  }

  .timeline-eyebrow {
    font-family: var(--font-body);
    font-size: 11px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--gold);
    margin: 0 0 48px 0;
    text-align: center;
  }

  .timeline-track {
    position: relative;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0;
  }

  .timeline-line {
    position: absolute;
    top: 10px;
    left: 10%;
    right: 10%;
    height: 1px;
    background: linear-gradient(to right, transparent, rgba(200,164,90,0.5) 15%, rgba(200,164,90,0.5) 85%, transparent);
    z-index: 0;
  }

  .timeline-item {
    position: relative;
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 0 12px;
    cursor: default;
  }

  .timeline-dot {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    border: 1.5px solid var(--gold);
    background: var(--olive);
    box-shadow: 0 0 0 4px rgba(200,164,90,0.12);
    margin-bottom: 16px;
    position: relative;
    z-index: 1;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .timeline-item:hover .timeline-dot {
    transform: scale(1.35);
    box-shadow: 0 0 0 6px rgba(200,164,90,0.2), 0 0 18px rgba(200,164,90,0.35);
    background: var(--gold);
  }

  .timeline-year {
    font-family: var(--font-body);
    font-size: 11px;
    letter-spacing: 0.15em;
    color: var(--gold);
    margin-bottom: 8px;
    font-weight: 600;
  }

  .timeline-title {
    font-family: var(--font-display);
    font-size: 15px;
    color: var(--cream);
    margin-bottom: 10px;
    line-height: 1.3;
  }

  .timeline-desc {
    font-family: var(--font-body);
    font-size: 12px;
    color: rgba(245, 240, 232, 0.5);
    line-height: 1.7;
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s ease, opacity 0.4s ease, color 0.3s ease;
    opacity: 0;
  }

  .timeline-item:hover .timeline-desc {
    max-height: 160px;
    opacity: 1;
    color: rgba(245, 240, 232, 0.75);
  }

  /* ─── BIO ─── */
  .bio {
    padding: 80px 72px;
    display: grid;
    grid-template-columns: 420px 1fr;
    gap: 80px;
    max-width: 1400px;
    position: relative;
    z-index: 1;
  }

  .bio-sidebar {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .stat-label {
    font-family: var(--font-body);
    font-weight: 200;
    font-size: 9px;
    letter-spacing: 0.45em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 8px;
  }

  .stat-value {
    font-family: var(--font-display);
    font-size: 17px;
    color: var(--cream);
    line-height: 1.55;
  }

  .stat-value em {
    font-style: italic;
    color: var(--gold-light);
  }

  .bio-body p {
    font-family: var(--font-display);
    font-size: 19px;
    line-height: 1.95;
    color: var(--text-muted);
    margin-bottom: 28px;
  }

  .bio-body p:last-child {
    margin-bottom: 0;
  }

  .bio-body strong {
    color: var(--cream);
    font-weight: 600;
  }

  .bio-body .hl {
    font-style: italic;
    color: var(--gold-light);
  }

  /* ─── CREDENTIALS ─── */
  .credentials {
    padding: 0 72px 80px;
    position: relative;
    z-index: 1;
  }

  .cred-label {
    font-family: var(--font-body);
    font-weight: 200;
    font-size: 9px;
    letter-spacing: 0.5em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 36px;
  }

  .cred-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .cred-card {
    border: 1px solid rgba(200,164,90,0.18);
    padding: 36px 28px;
    position: relative;
    overflow: hidden;
    transition: background 0.4s, border-color 0.4s;
  }

  .cred-card::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
    transform: scaleX(0);
    transition: transform 0.5s;
    transform-origin: left;
  }

  .cred-card:hover {
    background: rgba(200,164,90,0.04);
    border-color: rgba(200,164,90,0.35);
  }

  .cred-card:hover::after {
    transform: scaleX(1);
  }

  .cred-abbr {
    font-family: var(--font-display);
    font-size: 38px;
    font-weight: 600;
    font-style: italic;
    color: rgba(200,164,90,0.2);
    margin-bottom: 16px;
    line-height: 1;
  }

  .cred-name {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 10px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 10px;
  }

  .cred-desc {
    font-family: var(--font-display);
    font-size: 16px;
    line-height: 1.7;
    color: var(--text-muted);
  }

  /* ─── ANIMATIONS ─── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(22px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.85s ease, transform 0.85s ease;
  }

  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 900px) {
    .hero,
    .pull-quote,
    .bio,
    .credentials {
      padding-left: 24px;
      padding-right: 24px;
    }

    .timeline-section {
      padding: 60px 24px 40px;
    }

    .timeline-track {
      flex-direction: column;
      align-items: flex-start;
      gap: 32px;
    }

    .timeline-line {
      display: none;
    }

    .timeline-item {
      flex-direction: row;
      align-items: flex-start;
      text-align: left;
      padding: 0;
      gap: 20px;
    }

    .timeline-dot {
      margin-bottom: 0;
      flex-shrink: 0;
      margin-top: 3px;
    }

    .timeline-desc {
      max-height: 200px;
      opacity: 1;
      color: rgba(245, 240, 232, 0.65);
    }

    .hero-content {
      flex-direction: column;
    }

    .hero-illustration {
      width: 320px;
      margin-right: 0;
      margin-bottom: 0;
      align-self: center;
    }

    .bio {
      grid-template-columns: 1fr;
      gap: 48px;
    }

    .cred-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-label,
    .hero-name,
    .hero-sub,
    .hero-ghost {
      opacity: 1;
      animation: none;
    }

    .orb,
    .hero-illustration {
      animation: none;
    }

    .reveal {
      opacity: 1;
      transform: none;
    }
  }
</style>

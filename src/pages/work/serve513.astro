    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-fade {
      opacity: 1;
      transform: none;
      animation: none;
    }
    .reveal {
      opacity: 1;
      transform: none;
    }
    .cascade li,
    .stagger-card,
    .sol-card,
    .goal-col {
      opacity: 1;
      transform: none;
    }
  }
</style>

  }

  .callout p {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(20px, 2.4vw, 26px);
    line-height: var(--leading-snug);
    color: var(--gold-light);
    margin: 0;
  }

  /* ─── LISTS ─── */
  .cs-list {
    list-style: none;
    padding: 0;
    margin-bottom: 16px;
  }

  .cs-list li {
    font-family: var(--font-display);
    font-size: var(--text-lg);

  .sol-card:nth-child(odd) {
    border-right: 1px solid rgba(200, 164, 90, 0.18);
  }

  .visible .sol-card {
    opacity: 1;
    transform: translateY(0);
  }

  .sol-name {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: var(--weight-regular);
    font-size: var(--text-xl);
    color: var(--gold-light);
    margin-bottom: 10px;
  }

  .sol-desc {
    font-family: var(--font-display);
    font-size: var(--text-base);
    color: var(--cream);
    line-height: var(--leading-relaxed);
  }

  .stagger-card {
    opacity: 0;
    transform: translateY(14px);
    transition: opacity 0.55s ease, transform 0.55s ease;
  }

  .visible .stagger-card {
    opacity: 1;
    transform: translateY(0);
  }

  /* ─── LEARN BLOCKS — flat with prominent gold number ─── */
  .learn-block {
    padding: 32px 0;
    margin-bottom: 0;
    border-bottom: 1px solid rgba(200, 164, 90, 0.18);
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 24px;
    align-items: baseline;
  }

  .learn-block:last-of-type {
    border-bottom: none;
  }

  .learn-num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: var(--weight-light);
    font-size: var(--text-3xl);
    color: var(--gold);
    line-height: 1;
    grid-row: 1 / span 2;
  }

  .learn-head {
    font-family: var(--font-display);
    font-weight: var(--weight-regular);
    font-size: var(--text-xl);
    color: var(--gold-light);
    margin-bottom: 12px;
    line-height: var(--leading-snug);
  }

  .learn-body {
    font-family: var(--font-display);
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--cream);
  }

  /* ─── TIMELINE / ROADMAP ─── */
  .timeline-scroll {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    margin: 32px 0 24px;
    padding-bottom: 8px;
    scrollbar-width: thin;
    scrollbar-color: var(--gold) transparent;
  }

  .timeline {
    display: flex;
    align-items: flex-start;
    position: relative;
    min-width: 580px;
    padding: 0 20px;
  }

  .timeline-line {
    position: absolute;
    top: 10px;
    left: 20px;
    right: 20px;
    height: 1px;
    background: linear-gradient(to right, var(--gold), rgba(200, 164, 90, 0.3));
  }

  .tl-node {
    flex: 1;
    text-align: center;
    cursor: pointer;
    position: relative;
    padding-top: 32px;
    transition: transform 0.2s;
  }

  .tl-node:hover {
    transform: translateY(-2px);
  }

  .tl-dot {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    border: 2px solid var(--gold);
    background: var(--olive);
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    transition: background 0.3s, box-shadow 0.3s, transform 0.3s;
  }

  .tl-dot.active {
    background: var(--gold);
  }

  .tl-node.tl-selected .tl-dot {
    box-shadow: 0 0 0 5px rgba(200, 164, 90, 0.25);
    transform: translateX(-50%) scale(1.2);
  }

  .tl-phase {
    font-family: var(--font-body);
    font-weight: var(--weight-medium);
    font-size: var(--text-2xs);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold);
    margin-top: 12px;
    margin-bottom: 6px;
  }

  .tl-title {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: var(--weight-regular);
    font-size: var(--text-base);
    color: var(--cream);
    line-height: var(--leading-snug);
    padding: 0 8px;
    transition: color 0.3s;
  }

  .tl-node.tl-selected .tl-title {
    color: var(--gold-light);
  }

  .tl-hint {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--text-sm);
    color: var(--text-muted);
    text-align: center;
    margin-top: 8px;
  }

  /* Detail panel — flat */
  .tl-detail {
    border-top: 1px solid rgba(200, 164, 90, 0.18);
    padding: 0 0;
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.5s ease, padding 0.5s ease;
    margin-top: 24px;
  }

  .tl-detail.tl-detail-open {
    max-height: 360px;
    padding: 28px 0 0;
  }

  .tl-detail-panel {
    display: none;
  }

  .tl-detail-panel.tl-panel-active {
    display: block;
    animation: panelFade 0.4s ease;
  }

  @keyframes panelFade {
    from { opacity: 0; transform: translateY(6px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .tl-detail-phase {
    font-family: var(--font-body);
    font-weight: var(--weight-medium);
    font-size: var(--text-2xs);
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 12px;
    display: block;
  }

  .tl-detail-head {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: var(--weight-regular);
    font-size: var(--text-2xl);
    color: var(--gold-light);
    margin-bottom: 12px;
    line-height: var(--leading-snug);
  }

  .tl-detail-body {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    line-height: var(--leading-loose);
    color: var(--cream);
  }

  /* ─── WHY BLOCK — flat finale ─── */
  .why-block {
    padding: 80px 0 100px;
    margin-top: 64px;
    border-top: 1px solid rgba(200, 164, 90, 0.18);
    text-align: center;
  }

  .why-headline {
    font-family: var(--font-display);
    font-weight: var(--weight-light);
    font-size: clamp(28px, 4.5vw, 44px);
    line-height: var(--leading-snug);
    color: var(--cream);
    margin-bottom: 24px;
    letter-spacing: var(--tracking-tight);
  }

  .why-headline em {
    font-style: italic;
    color: var(--gold-light);
  }

  .why-text {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--text-muted);
    max-width: 540px;
    margin: 0 auto 36px;
  }

  .why-cta-row {
    display: flex;
    gap: 28px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .why-cta,
  .why-cta-secondary {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: var(--weight-regular);
    font-size: var(--text-xl);
    text-decoration: none;
    padding: 4px 0 6px;
    transition: color 0.25s;
    position: relative;
    display: inline-block;
  }

  .why-cta {
    color: var(--gold-light);
    border-bottom: 2px solid var(--gold);
  }

  .why-cta-secondary {
    color: var(--cream);
    border-bottom: 2px solid rgba(200, 164, 90, 0.5);
  }

  .why-cta::after,
  .why-cta-secondary::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -2px;
    width: 0;
    height: 2px;
    background: var(--cream);
    transition: width 0.35s ease;
  }

  .why-cta:hover,
  .why-cta-secondary:hover {
    color: var(--cream);
  }

  .why-cta:hover::after,
  .why-cta-secondary:hover::after {
    width: 100%;
  }

  /* ─── ANIMATIONS ─── */
  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.85s ease, transform 0.85s ease;
  }

  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 700px) {
    .cs-body {
      padding: 0 24px;
    }

    .cs-hero {
      padding-top: 100px;
    }

    .metrics-banner {
      grid-template-columns: repeat(2, 1fr);
    }

    .m-cell:nth-child(2) {
      border-right: none;
    }

    .meta-strip {
      flex-direction: column;
    }

    .meta-cell + .meta-cell {
      border-left: none;
      border-top: 1px solid rgba(200, 164, 90, 0.18);
      padding-left: 0;
      padding-top: 16px;
    }

    .goal-cols {
      grid-template-columns: 1fr;
    }

    .goal-col + .goal-col {
      border-left: none;
      border-top: 1px solid rgba(200, 164, 90, 0.18);
    }

    .solution-grid {
      grid-template-columns: 1fr;
    }

    .sol-card:nth-child(odd) {
      border-right: none;
    }

    .learn-block {
      grid-template-columns: 1fr;
      gap: 12px;
    }

    .learn-num {
      grid-row: auto;
    }

    .why-block {
      padding: 56px 0 72px;
    }
  }

  /* Tablet — between mobile and desktop, drop 4-col metrics to 2 and tighten padding */
  @media (max-width: 1000px) and (min-width: 701px) {
    .cs-body {
      padding: 0 40px;
    }
    .metrics-banner {
      grid-template-columns: repeat(2, 1fr);
    }
    .m-cell:nth-child(2) {
      border-right: none;
    }
    .m-cell:nth-child(3),
    .m-cell:nth-child(4) {
      border-top: 1px solid rgba(200, 164, 90, 0.18);
    }
    .goal-cols {
      grid-template-columns: 1fr;
    }
    .goal-col + .goal-col {
      border-left: none;
      border-top: 1px solid rgba(200, 164, 90, 0.18);
    }
    .learn-block {
      grid-template-columns: 64px 1fr;
      gap: 20px;
    }
    .learn-num {

    <div class="cs-glow-a"></div>
    <div class="cs-glow-b"></div>

    <svg class="cs-leaf-bg" viewBox="0 0 600 500" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice">

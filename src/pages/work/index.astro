        <path d="M-30,30 C80,0 200,50 320,20" stroke-width="1.2"/>
        <path d="M-30,30 C60,55 140,80 200,72" stroke-width="0.5"/>
        <path d="M10,32 C50,22 100,38 150,28" stroke-width="0.4"/>
        <path d="M60,28 C100,18 160,34 210,24" stroke-width="0.4"/>
        <path d="M120,26 C160,14 220,30 275,18" stroke-width="0.4"/>
        <path d="M180,24 C220,12 280,28 330,16" stroke-width="0.35"/>
        <path d="M240,22 C280,10 340,24 390,12" stroke-width="0.35"/>
      </g>
      <g opacity="0.17" stroke="#e2c07a" fill="none">
        <path d="M520,-20 C540,80 570,180 600,260" stroke-width="1.1"/>
        <path d="M520,-20 C530,80 535,180 540,260" stroke-width="0.5"/>
        <path d="M522,20 C548,30 566,50 578,75" stroke-width="0.38"/>
        <path d="M524,65 C550,76 568,96 580,122" stroke-width="0.38"/>
        <path d="M526,110 C552,122 570,142 582,168" stroke-width="0.38"/>
        <path d="M528,155 C554,168 572,188 584,214" stroke-width="0.35"/>
        <path d="M530,200 C556,214 574,234 586,260" stroke-width="0.35"/>
      </g>
      <g opacity="0.15" stroke="#c8a45a" fill="none">
        <path d="M-20,420 C100,385 240,405 380,370" stroke-width="1.1"/>
        <path d="M-20,420 C80,435 180,445 280,440" stroke-width="0.5"/>
        <path d="M20,418 C70,404 130,414 180,400" stroke-width="0.38"/>
        <path d="M80,414 C130,400 190,410 240,396" stroke-width="0.38"/>
        <path d="M150,410 C200,396 260,406 310,392" stroke-width="0.35"/>
        <path d="M220,406 C270,392 330,402 380,388" stroke-width="0.35"/>
      </g>
      <g opacity="0.11" stroke="#e2c07a" fill="none">
        <path d="M600,220 C480,245 340,225 180,260" stroke-width="1"/>
        <path d="M600,220 C480,265 340,268 180,300" stroke-width="0.5"/>
        <path d="M560,222 C520,236 470,230 420,244" stroke-width="0.35"/>
        <path d="M500,228 C460,242 410,236 360,250" stroke-width="0.35"/>
        <path d="M430,234 C390,248 340,242 290,256" stroke-width="0.32"/>
        <path d="M360,240 C320,254 270,248 220,262" stroke-width="0.32"/>
      </g>
      <g opacity="0.13" stroke="#c8a45a" fill="none">
        <path d="M600,360 C520,330 420,350 320,320" stroke-width="1"/>
        <path d="M600,360 C520,375 440,380 360,375" stroke-width="0.5"/>
        <path d="M570,358 C540,344 500,352 460,338" stroke-width="0.36"/>
        <path d="M520,354 C490,340 450,348 410,334" stroke-width="0.36"/>
        <path d="M460,350 C430,336 390,344 350,330" stroke-width="0.32"/>
      </g>
    </svg>

    <div class="cs-card-wrap">
      <a href="/work/serve513" class="cs-card">
        <div class="cs-card-inner">
          <p class="section-eyebrow">Case Study</p>
          <h2 class="cs-card-title">SERVE<em>513</em></h2>
          <p class="cs-hook">Volunteers were burning out. Clients were waiting too long. The systems meant to help were getting in the way — so I built something better.</p>
          <hr class="cs-divider">
          <div class="cs-metrics">
            <div class="cs-metric cs-stat" id="s1">
              <span class="cs-metric-val cs-num" id="n1">0%</span>
              <div class="cs-before-after">
                <span class="cs-ba-val cs-ba-old">45 min</span>
                <span class="cs-ba-arrow">&rarr;</span>
                <span class="cs-ba-val cs-ba-new">under 10 min</span>
              </div>
              <span class="cs-metric-lbl">Clothing wait time reduction</span>
              <span class="cs-stat-context">Waitlists at shelters can last all day — every minute saved matters</span>
            </div>
            <div class="cs-metric cs-stat" id="s2">
              <span class="cs-metric-val cs-num" id="n2">0%</span>
              <div class="cs-before-after cs-spacer-ba" style="visibility:hidden;height:18px;"></div>
              <span class="cs-metric-lbl">Volunteer adoption rate</span>
              <span class="cs-stat-context">No training overhead — volunteers used it under real event pressure</span>
            </div>
            <div class="cs-metric cs-stat" id="s3">
              <span class="cs-metric-val cs-num" id="n3">0%</span>
              <div class="cs-before-after">
                <span class="cs-ba-val cs-ba-old">23</span>
                <span class="cs-ba-arrow">&rarr;</span>
                <span class="cs-ba-val cs-ba-new">27 showers</span>
              </div>
              <span class="cs-metric-lbl">More shower capacity</span>
              <span class="cs-stat-context">Hygiene access is a direct barrier to employment and housing stability</span>
            </div>
          </div>
          <span class="cs-read">Read the Case Study &rarr;</span>
        </div>
      </a>
    </div>
  </div>

  <!-- GOLD DIVIDER -->
  <svg class="gold-divider" viewBox="0 0 1440 48" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
    <line x1="72" y1="24" x2="400" y2="24" stroke="rgba(200,164,90,0.4)" stroke-width="0.75"/>
    <circle cx="400" cy="24" r="2.5" fill="none" stroke="rgba(200,164,90,0.5)" stroke-width="1"/>
    <line x1="406" y1="24" x2="700" y2="24" stroke="rgba(200,164,90,0.2)" stroke-width="0.5" stroke-dasharray="4 6"/>
    <circle cx="700" cy="24" r="1.5" fill="rgba(200,164,90,0.4)"/>
    <line x1="706" y1="24" x2="1040" y2="24" stroke="rgba(200,164,90,0.2)" stroke-width="0.5" stroke-dasharray="4 6"/>
    <circle cx="1040" cy="24" r="2.5" fill="none" stroke="rgba(200,164,90,0.5)" stroke-width="1"/>
    <line x1="1046" y1="24" x2="1370" y2="24" stroke="rgba(200,164,90,0.4)" stroke-width="0.75"/>
  </svg>

  <!-- NOT-FOR-PROFIT SECTION -->
  <section class="work-section reveal">
    <p class="section-eyebrow">Not-for-Profit</p>
    <h2 class="section-heading">Say Hello <em>Neighbor</em></h2>
    <div class="work-grid">
      <div class="work-detail">
        <div class="work-stats">
          <div>
            <p class="stat-label">Role</p>
            <p class="stat-value">Founder &amp; Product Lead</p>
          </div>
          <div>
            <p class="stat-label">Focus</p>
            <p class="stat-value"><em>Community Outreach</em></p>
          </div>
          <div>
            <p class="stat-label">Status</p>
            <p class="stat-value">Active</p>
          </div>
        </div>
      </div>
      <div class="work-body">
        <p>
          <strong>Say Hello Neighbor</strong> is a not-for-profit initiative focused on
          bridging the gap between communities and the resources they need. The mission is simple —
          <span class="hl">meet people where they are and connect them to what matters.</span>
        </p>
        <p>
          From coordinating outreach events to building systems that help volunteers and organizations
          work together more effectively, Say Hello Neighbor is built on the belief that
          <strong>showing up is the first step to making change.</strong>
        </p>
        <p>
          The work spans resource coordination, volunteer management, and community engagement —
          all driven by <span class="hl">empathy, intentional design, and a commitment to serving
          those who are often overlooked.</span>
        </p>
      </div>
    </div>
  </section>

  <!-- GOLD DIVIDER -->
  <svg class="gold-divider" viewBox="0 0 1440 48" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M0 24 Q180 4 360 24 T720 24 T1080 24 T1440 24" fill="none" stroke="rgba(200,164,90,0.35)" stroke-width="1"/>
    <path d="M0 32 Q240 48 480 28 T960 32 T1440 28" fill="none" stroke="rgba(226,192,122,0.15)" stroke-width="0.75"/>
    <circle cx="360" cy="24" r="3" fill="rgba(200,164,90,0.5)"/>
    <circle cx="720" cy="24" r="2" fill="rgba(200,164,90,0.4)"/>
    <circle cx="1080" cy="24" r="3" fill="rgba(200,164,90,0.5)"/>
  </svg>

  <!-- CONSULTING SECTION -->
  <section class="work-section reveal">
    <p class="section-eyebrow">Consulting</p>
    <h2 class="section-heading">SALT TPA <em>Outpost</em></h2>
    <div class="work-grid">
      <div class="work-detail">
        <div class="work-stats">
          <div>
            <p class="stat-label">Role</p>
            <p class="stat-value">Product Consultant</p>
          </div>
          <div>
            <p class="stat-label">Focus</p>
            <p class="stat-value"><em>Strategy &amp; Operations</em></p>
          </div>
          <div>
            <p class="stat-label">Status</p>
            <p class="stat-value">Active</p>
          </div>
        </div>
      </div>
      <div class="work-body">
        <p>
          <strong>SALT TPA Outpost</strong> is a consulting engagement where product thinking meets
          real-world operational challenges. Working closely with the team to
          <span class="hl">define strategy, streamline processes, and build systems that scale.</span>
        </p>
        <p>
          The work focuses on translating complex business needs into clear, actionable roadmaps —
          aligning stakeholders, identifying opportunities, and ensuring that
          <strong>every decision is rooted in purpose and impact.</strong>
        </p>
        <p>
          From discovery and requirements gathering to delivery and iteration,
          this partnership is about <span class="hl">bringing clarity to complexity
          and helping organizations move forward with confidence.</span>
        </p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="work-cta-section reveal">
    <p class="cta-label">Interested in Working Together?</p>
    <h2 class="cta-heading">Let's Build Something <em>Meaningful</em></h2>
    <a href="/contact" class="work-cta">Get in Touch</a>
  </section>

</Layout>

<script>
  function countUp(el, target, delay, decimals) {
    setTimeout(() => {
      el.closest('.cs-stat').classList.add('cs-stat-visible');
      let val = 0;
      const inc = target / (950 / 16);
      const t = setInterval(() => {
        val = Math.min(val + inc, target);
        el.textContent = (decimals ? val.toFixed(1) : Math.round(val)) + '%';
        if (val >= target) {
          el.textContent = target.toFixed(decimals ? 1 : 0) + '%';
          clearInterval(t);
        }
      }, 16);
    }, delay);
  }

  function initWorkPage() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);

          // Trigger count-up when the case study card becomes visible
          if (entry.target.classList.contains('cs-outer')) {
            const n1 = document.getElementById('n1');
            const n2 = document.getElementById('n2');
            const n3 = document.getElementById('n3');
            if (n1 && n2 && n3) {
              countUp(n1, 90, 100, false);
              countUp(n2, 95, 320, false);
              countUp(n3, 17.4, 540, true);
            }
          }
        }
      });
    }, { threshold: 0.05 });

    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

    // Safety net — force all reveals visible after 3s
    setTimeout(() => {
      document.querySelectorAll('.reveal:not(.visible)').forEach(el => {
        el.classList.add('visible');
      });
      document.querySelectorAll('.cs-stat:not(.cs-stat-visible)').forEach(el => {
        el.classList.add('cs-stat-visible');
      });
    }, 3000);
  }

  document.addEventListener('astro:page-load', initWorkPage);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initWorkPage);
  } else {
    initWorkPage();
  }
</script>

<style>
  /* ─── ORB LAYER ─── */
  .orb-layer {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .orb {
    position: absolute;
    border-radius: 50%;
  }

  .orb-a {
    width: 280px; height: 280px; top: 12vh; left: 6vw;
    background: radial-gradient(circle, rgba(200,164,90,0.14) 0%, transparent 70%);
    animation: floatOrb 9s ease-in-out infinite;
  }

  .orb-b {
    width: 180px; height: 180px; top: 40vh; right: 8vw;
    background: radial-gradient(circle, rgba(226,192,122,0.16) 0%, transparent 70%);
    animation: floatOrb 11s ease-in-out 2s infinite;
  }

  .orb-c {
    width: 120px; height: 120px; top: 65vh; left: 22vw;
    background: radial-gradient(circle, rgba(200,164,90,0.18) 0%, transparent 70%);
    animation: floatOrb 8s ease-in-out 1s infinite;
  }

  .orb-d {
    width: 200px; height: 200px; bottom: 15vh; right: 12vw;
    background: radial-gradient(circle, rgba(226,192,122,0.12) 0%, transparent 70%);
    animation: floatOrb 13s ease-in-out 3s infinite;
  }

  @keyframes floatOrb {
    0%, 100% { transform: translateY(0) scale(1); }
    50% { transform: translateY(-30px) scale(1.06); }
  }

  /* ─── HERO ─── */
  .hero {
    padding: 160px 72px 80px;
    position: relative;
    z-index: 1;
  }

  .hero-label {
    font-family: var(--font-body);
    font-weight: 200;
    font-size: 9px;
    letter-spacing: 0.55em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 24px;
    opacity: 0;
    animation: fadeUp 0.9s ease 0.1s forwards;
  }

  .hero-name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(72px, 12vw, 150px);
    line-height: 0.88;
    letter-spacing: -0.02em;
    color: var(--cream);
    opacity: 0;
    animation: fadeUp 0.9s ease 0.25s forwards;
  }

  .hero-name em {
    font-style: italic;
    color: var(--gold-light);
    display: block;
  }

  .hero-sub {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(17px, 2vw, 26px);
    line-height: 1.6;
    color: var(--text-muted);
    margin-top: 36px;
    max-width: 600px;
    opacity: 0;
    animation: fadeUp 0.9s ease 0.5s forwards;
  }

  .hero-ghost {
    position: absolute;
    right: 40px;
    top: 110px;
    font-family: var(--font-display);
    font-weight: 600;
    font-style: italic;
    font-size: clamp(100px, 18vw, 200px);
    color: transparent;
    -webkit-text-stroke: 1px rgba(200,164,90,0.10);
    pointer-events: none;
    user-select: none;
    opacity: 0;
    animation: fadeIn 1.4s ease 0.9s forwards;
  }

  /* ─── GOLD DIVIDER ─── */
  .gold-divider {
    width: 100%;
    overflow: visible;
    display: block;
    margin: 0;
    height: 48px;
    position: relative;
    z-index: 1;
  }

  /* ─── WORK SECTIONS ─── */
  .work-section {
    padding: 80px 72px;
    position: relative;
    z-index: 1;
  }

  .section-eyebrow {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 11px;
    letter-spacing: 0.55em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 20px;
  }

  .section-heading {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(36px, 5vw, 64px);
    line-height: 0.92;
    color: var(--cream);
    margin-bottom: 48px;
  }

  .section-heading em {
    font-style: italic;
    color: var(--gold-light);
  }

  .work-grid {
    display: grid;
    grid-template-columns: 340px 1fr;
    gap: 72px;
  }

  .work-stats {
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  .stat-label {
    font-family: var(--font-body);
    font-weight: 200;
    font-size: 9px;
    letter-spacing: 0.45em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 6px;
  }

  .stat-value {
    font-family: var(--font-display);
    font-size: 17px;
    color: var(--cream);
    line-height: 1.55;
  }

  .stat-value em {
    font-style: italic;
    color: var(--gold-light);
  }

  .work-body p {
    font-family: var(--font-display);
    font-size: 19px;
    line-height: 1.95;
    color: var(--text-muted);
    margin-bottom: 28px;
  }

  .work-body p:last-child {
    margin-bottom: 0;
  }

  .work-body strong {
    color: var(--cream);
    font-weight: 600;
  }

  .work-body .hl {
    font-style: italic;
    color: var(--gold-light);
  }

  /* ─── CASE STUDY CARD ─── */
  .cs-outer {
    background: #2a2218;
    border-radius: 16px;
    position: relative;
    overflow: hidden;
    padding: 28px;
    margin: 40px 72px;
    z-index: 1;
  }

  .cs-glow-a {
    position: absolute;
    top: -80px; right: -80px;
    width: 360px; height: 360px;
    background: radial-gradient(circle, rgba(200,164,90,0.16) 0%, rgba(200,164,90,0.05) 50%, transparent 70%);
    pointer-events: none;
    border-radius: 50%;
  }

  .cs-glow-b {
    position: absolute;
    bottom: -100px; left: -60px;
    width: 280px; height: 280px;
    background: radial-gradient(circle, rgba(200,164,90,0.08) 0%, transparent 65%);
    pointer-events: none;
    border-radius: 50%;
  }

  .cs-leaf-bg {
    position: absolute;
    inset: 0;
    width: 100%; height: 100%;
    pointer-events: none;
  }

  .cs-card-wrap {
    position: relative;
    z-index: 2;
  }

  .cs-card {
    display: block;
    text-decoration: none;
  }

  .cs-card-inner {
    background: #342b1e;
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 40px 44px;
    position: relative;
    overflow: hidden;
    transition: border-color 0.4s ease, box-shadow 0.4s ease;
  }

  .cs-card-inner::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: var(--gold);
  }

  .cs-card:hover .cs-card-inner {
    border-color: rgba(200,164,90,0.35);
    box-shadow: 0 8px 60px rgba(200,164,90,0.1);
  }

  .cs-card-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 30px;
    line-height: 1.1;
    color: var(--cream);
    margin-bottom: 14px;
  }

  .cs-card-title em {
    font-style: italic;
    color: var(--gold-light);
  }

  .cs-hook {
    font-family: var(--font-body);
    font-size: 17px;
    line-height: 1.75;
    color: var(--text-muted);
    margin-bottom: 28px;
  }

  .cs-divider {
    border: none;
    border-top: 1px solid var(--border);
    margin: 0 0 28px;
  }

  .cs-metrics {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin-bottom: 32px;
  }

  .cs-metric {
    padding-right: 24px;
  }

  .cs-stat {
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }

  .cs-stat.cs-stat-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .cs-metric + .cs-metric {
    padding-left: 24px;
    padding-right: 0;
    border-left: 1px solid var(--border);
  }

  .cs-metric-val {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 28px;
    color: var(--gold);
    display: block;
    line-height: 1;
    margin-bottom: 5px;
    font-variant-numeric: tabular-nums;
  }

  .cs-before-after {
    display: flex;
    align-items: center;
    gap: 5px;
    margin-bottom: 6px;
    flex-wrap: wrap;
  }

  .cs-ba-val { font-size: 14px; font-weight: 500; }
  .cs-ba-old { text-decoration: line-through; color: rgba(245,240,232,0.4); }
  .cs-ba-arrow { font-size: 14px; color: var(--gold); }
  .cs-ba-new { color: var(--gold-light); }

  .cs-metric-lbl {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 16px;
    line-height: 1.5;
    color: var(--text-muted);
    margin-bottom: 8px;
    display: block;
  }

  .cs-stat-context {
    font-size: 13px;
    line-height: 1.6;
    color: rgba(245,240,232,0.55);
    font-style: italic;
    display: block;
    border-top: 1px solid var(--border);
    padding-top: 8px;
  }

  .cs-read {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 15px;
    color: var(--gold-light);
    letter-spacing: 0.03em;
    display: inline-flex;

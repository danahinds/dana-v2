---
import Layout from "../layouts/Layout.astro";
---

<Layout pageTitle="Contact — Dana Sandy" pageDescription="Reach out about product strategy, AI experimentation, the SKAI series, or just to say hello.">

  <div class="contact-body">

    <!-- HERO -->
    <section class="contact-hero">
      <p class="eyebrow">Let's talk</p>
      <h1 class="contact-title">Get <em>in touch</em></h1>
      <p class="contact-lede">Whether it's a product collaboration, an AI experiment, an update on the SKAI series, or just a hello — I'd love to hear from you.</p>
    </section>

    <div class="section-break" aria-hidden="true"><span></span><span class="dot"></span><span></span></div>

    <!-- TWO-COLUMN: info + form -->
    <section class="contact-grid">

      <aside class="contact-info">
        <div class="info-cell">
          <p class="info-label">Based in</p>
          <p class="info-value">Florida, <em>USA</em></p>
        </div>
        <div class="info-cell">
          <p class="info-label">Email</p>
          <p class="info-value"><a class="info-link" href="mailto:hello@danasandy.com">hello@danasandy.com</a></p>
        </div>
        <div class="info-cell">
          <p class="info-label">Currently</p>
          <p class="info-value">Open to product, partnership, and speaking conversations.</p>
        </div>
      </aside>

      <div class="contact-form-wrap">
        <div class="form-success" id="form-success" hidden>
          <p class="eyebrow">Thank you</p>
          <h2 class="success-title">Message <em>received</em>.</h2>
          <p class="success-text">I'll get back to you soon. In the meantime, you can also reach me at <a class="info-link" href="mailto:hello@danasandy.com">hello@danasandy.com</a>.</p>
        </div>

        <form
          class="contact-form"
          id="contact-form"
          name="contact"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          action="/contact?success=1"
        >
          <input type="hidden" name="form-name" value="contact" />
          <p class="hp-field"><label>Don't fill this out: <input name="bot-field" /></label></p>

          <div class="field">
            <label for="name">Name</label>
            <input type="text" id="name" name="name" autocomplete="name" required />
          </div>

          <div class="field">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" autocomplete="email" required />
          </div>

          <div class="field">
            <label for="subject">Subject</label>
            <select id="subject" name="subject" required>
              <option value="" disabled selected>Choose one</option>
              <option value="SKAI Series updates">SKAI Series updates</option>
              <option value="Collaboration">Collaboration</option>
              <option value="Product Management inquiry">Product Management inquiry</option>
              <option value="General hello">General hello</option>
            </select>
          </div>

          <div class="field">
            <label for="message">Message</label>
            <textarea id="message" name="message" rows="6" required></textarea>
          </div>

          <button type="submit" class="form-submit">Send message &rarr;</button>
        </form>
      </div>

    </section>

  </div>

</Layout>

<script>
  function initContactPage() {
    if (window.location.search.includes('success=1')) {
      const form = document.getElementById('contact-form');
      const success = document.getElementById('form-success');
      if (form) form.style.display = 'none';
      if (success) success.hidden = false;
    }
  }
  document.addEventListener('astro:page-load', initContactPage);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initContactPage);
  } else {
    initContactPage();
  }
</script>

<style>
  .contact-body {
    max-width: 1080px;
    margin: 0 auto;
    padding: 0 72px;
  }

  /* ─── HERO ─── */
  .contact-hero {
    padding: 140px 0 56px;
  }

  .eyebrow {
    font-family: var(--font-body);
    font-weight: var(--weight-regular);
    font-size: var(--text-2xs);
    letter-spacing: 0.45em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 18px;
  }

  .contact-title {
    font-family: var(--font-display);
    font-weight: var(--weight-light);
    font-size: clamp(56px, 9vw, 96px);
    line-height: 0.92;
    letter-spacing: var(--tracking-tight);
    color: var(--cream);
    margin-bottom: 28px;
  }

  .contact-title em {
    font-style: italic;
    color: var(--gold-light);
  }

  .contact-lede {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(20px, 2.4vw, 26px);
    line-height: var(--leading-relaxed);
    color: var(--cream);
    max-width: 720px;
  }

  /* ─── SECTION BREAK ─── */
  .section-break {
    display: flex;
    align-items: center;
    gap: 16px;
    margin: 0 0 64px;
  }
  .section-break span {
    flex: 1;
    height: 1px;
    background: rgba(200, 164, 90, 0.18);
  }
  .section-break .dot {
    flex: none;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--gold);
    opacity: 0.6;
  }

  /* ─── GRID ─── */
  .contact-grid {
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: 80px;
    padding-bottom: 120px;
  }

  /* ─── INFO COLUMN ─── */
  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 36px;
  }

  .info-label {
    font-family: var(--font-body);
    font-weight: var(--weight-medium);
    font-size: var(--text-2xs);
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 10px;
  }

  .info-value {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    line-height: var(--leading-snug);
    color: var(--cream);
  }

  .info-value em {
    font-style: italic;
    color: var(--gold-light);
  }

  .info-link {
    color: var(--gold-light);
    text-decoration: none;
    border-bottom: 1px solid rgba(226, 192, 122, 0.5);
    padding-bottom: 2px;
    transition: color 0.25s, border-color 0.25s;
  }

  .info-link:hover {
    color: var(--cream);
    border-color: var(--cream);
  }

  /* ─── FORM ─── */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .hp-field {
    position: absolute;
    left: -10000px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .field label {
    font-family: var(--font-body);
    font-weight: var(--weight-medium);
    font-size: var(--text-2xs);
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--gold);
  }

  .field input,
  .field select,
  .field textarea {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--cream);
    background: transparent;
    border: none;
    border-bottom: 1px solid rgba(200, 164, 90, 0.3);
    padding: 10px 0 12px;
    outline: none;
    transition: border-color 0.25s;
  }

  .field input:focus,
  .field select:focus,
  .field textarea:focus {
    border-bottom-color: var(--gold-light);
  }

  .field select {
    appearance: none;
    background-image: linear-gradient(45deg, transparent 50%, var(--gold) 50%),
                      linear-gradient(135deg, var(--gold) 50%, transparent 50%);
    background-position: calc(100% - 18px) center, calc(100% - 12px) center;
    background-size: 6px 6px, 6px 6px;
    background-repeat: no-repeat;
    cursor: pointer;
    padding-right: 32px;
  }

  .field select option {
    background: var(--olive-dark);
    color: var(--cream);
  }

  .field textarea {
    resize: vertical;
    min-height: 140px;
    font-family: var(--font-body);
    line-height: var(--leading-normal);
  }

  .form-submit {
    margin-top: 12px;
    align-self: flex-start;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: var(--weight-regular);
    font-size: var(--text-xl);
    color: var(--gold-light);
    background: transparent;
    border: none;
    border-bottom: 1px solid rgba(226, 192, 122, 0.5);
    padding: 4px 0 6px;
    cursor: pointer;
    transition: color 0.25s, border-color 0.25s;
  }

  .form-submit:hover {
    color: var(--cream);
    border-color: var(--cream);
  }

  /* ─── SUCCESS ─── */
  .form-success {
    padding: 32px 0;
  }

  .success-title {
    font-family: var(--font-display);
    font-weight: var(--weight-light);
    font-size: clamp(36px, 5vw, 56px);
    line-height: var(--leading-snug);
    color: var(--cream);
    margin: 16px 0 20px;
  }

  .success-title em {
    font-style: italic;
    color: var(--gold-light);
  }

  .success-text {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    line-height: var(--leading-loose);
    color: var(--cream);
    max-width: 540px;
  }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 900px) {
    .contact-body {
      padding: 0 24px;
    }
    .contact-hero {
      padding-top: 100px;
    }
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 48px;
      padding-bottom: 80px;
    }
  }
</style>
</content>
</invoke>